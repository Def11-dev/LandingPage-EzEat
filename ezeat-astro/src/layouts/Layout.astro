---
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title: string;
  description?: string;
  ctaAccent?: boolean;
}

const {
  title,
  description = 'EzEat — El primer sistema operativo inteligente para Hoteles, Restaurantes y Cafeterías (HORECA). PDV, Inventarios con IA, Kioskos de Autoservicio y más.',
  ctaAccent = false,
} = Astro.props;
---

<!doctype html>
<html lang="es" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <link rel="icon" type="image/png" href="/EZ eat (6).png" />

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;500;700;800&family=Inter:wght@400;500;600&family=JetBrains+Mono:wght@400;500&display=swap"
      rel="stylesheet"
    />
    <!-- Material Symbols -->
    <link
      href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@20..48,100..700,0..1,-50..200"
      rel="stylesheet"
    />

    <style is:global>
      /* Material icons default style */
      .material-symbols-outlined {
        font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        user-select: none;
      }
      .material-symbols-outlined.fill {
        font-variation-settings: 'FILL' 1, 'wght' 400, 'GRAD' 0, 'opsz' 24;
      }

      /* Scroll-triggered animation base states */
      [data-animate] {
        opacity: 0;
        transition: opacity 0.65s ease-out, transform 0.65s ease-out;
      }
      [data-animate="fade-up"]    { transform: translateY(28px); }
      [data-animate="fade-in"]    { transform: none; }
      [data-animate="slide-right"]{ transform: translateX(-28px); }
      [data-animate="slide-left"] { transform: translateX(28px); }
      [data-animate="scale-in"]   { transform: scale(0.93); }

      [data-animate].is-visible {
        opacity: 1;
        transform: none !important;
      }

      /* Stagger delays for child items */
      [data-stagger] > * {
        opacity: 0;
        transform: translateY(20px);
        transition: opacity 0.5s ease-out, transform 0.5s ease-out;
      }
      [data-stagger].is-visible > * { opacity: 1; transform: none; }
      [data-stagger].is-visible > *:nth-child(1) { transition-delay: 0s;   }
      [data-stagger].is-visible > *:nth-child(2) { transition-delay: 0.1s; }
      [data-stagger].is-visible > *:nth-child(3) { transition-delay: 0.2s; }
      [data-stagger].is-visible > *:nth-child(4) { transition-delay: 0.3s; }
      [data-stagger].is-visible > *:nth-child(5) { transition-delay: 0.4s; }
      [data-stagger].is-visible > *:nth-child(6) { transition-delay: 0.5s; }
      [data-stagger].is-visible > *:nth-child(7) { transition-delay: 0.6s; }
      [data-stagger].is-visible > *:nth-child(8) { transition-delay: 0.7s; }

      /* Floating element keyframe */
      @keyframes float {
        0%, 100% { transform: translateY(0px); }
        50%       { transform: translateY(-8px); }
      }
      .animate-float { animation: float 4s ease-in-out infinite; }

      /* Smooth page load */
      body { animation: fade-in-page 0.4s ease-out; }
      @keyframes fade-in-page {
        from { opacity: 0; }
        to   { opacity: 1; }
      }
    </style>
  </head>

  <body class="bg-background text-on-background font-body antialiased selection:bg-primary-container selection:text-on-primary-container">
    <Navbar />
    <main class="pt-20">
      <slot />
    </main>
    <Footer />

    <!-- Floating diagnostic CTA widget -->
    <div class="fixed bottom-6 right-6 z-50 flex flex-col items-end gap-2 group">
      <!-- Label bubble — always visible, pulses subtly -->
      <a
        id="diag-cta-btn"
        href="/#diagnostico"
        class={`flex items-center gap-2 ${ctaAccent ? 'bg-accent text-on-accent' : 'bg-primary text-on-primary'} text-xs font-label font-semibold px-4 py-2.5 rounded-xl ${ctaAccent ? 'shadow-[0_4px_20px_rgba(230,82,0,0.45)]' : 'shadow-[0_4px_20px_rgba(43,73,243,0.45)]'} whitespace-nowrap hover:brightness-110 transition-all duration-200`}
        style={`animation: ${ctaAccent ? 'diag-pulse-accent' : 'diag-pulse'} 3s ease-in-out infinite;`}
      >
        <span class="material-symbols-outlined text-sm leading-none">insights</span>
        Iniciar diagnóstico gratis
        <span class="material-symbols-outlined text-sm leading-none">arrow_forward</span>
      </a>

      <!-- Mascot face button -->
      <a
        href="/#diagnostico"
        aria-label="Iniciar diagnóstico de eficiencia"
        class={`w-16 h-16 rounded-full overflow-hidden border-[3px] hover:scale-110 transition-all duration-200 block ${ctaAccent ? 'border-accent shadow-[0_4px_24px_rgba(230,82,0,0.5)] hover:shadow-[0_6px_32px_rgba(230,82,0,0.65)]' : 'border-primary shadow-[0_4px_24px_rgba(43,73,243,0.5)] hover:shadow-[0_6px_32px_rgba(43,73,243,0.65)]'}`}
        style="background: #ffffff url('/mascot.png') no-repeat 50% 15% / 360%;"
      ></a>
    </div>

    <style>
      @keyframes diag-pulse {
        0%, 100% { box-shadow: 0 4px 20px rgba(43,73,243,0.45); }
        50%       { box-shadow: 0 4px 28px rgba(43,73,243,0.75), 0 0 0 4px rgba(43,73,243,0.15); }
      }
      @keyframes diag-pulse-accent {
        0%, 100% { box-shadow: 0 4px 20px rgba(230,82,0,0.45); }
        50%       { box-shadow: 0 4px 28px rgba(230,82,0,0.75), 0 0 0 4px rgba(230,82,0,0.15); }
      }
    </style>

    <script>
      // If URL contains /#diagnostico, auto-trigger the quiz start button
      if (window.location.hash === '#diagnostico') {
        const btn = document.getElementById('btn-start');
        if (btn) btn.click();
      }
      // Floating button: on home page click triggers quiz; elsewhere navigates home
      document.getElementById('diag-cta-btn')?.addEventListener('click', (e) => {
        const btn = document.getElementById('btn-start');
        if (btn) { e.preventDefault(); btn.click(); }
      });
    </script>

    <!-- IntersectionObserver for scroll animations -->
    <script>
      const animateEls  = document.querySelectorAll('[data-animate]');
      const staggerEls  = document.querySelectorAll('[data-stagger]');

      const observer = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              entry.target.classList.add('is-visible');
              observer.unobserve(entry.target);
            }
          });
        },
        { threshold: 0.12, rootMargin: '0px 0px -40px 0px' }
      );

      [...animateEls, ...staggerEls].forEach((el) => observer.observe(el));
    </script>
  </body>
</html>

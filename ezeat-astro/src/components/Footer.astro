---
const currentYear = new Date().getFullYear();

const products = [
  { href: '/services', label: 'Soluciones' },
  { href: '/pricing',  label: 'Precios' },
  { href: '/contact',  label: 'Contacto' },
];

const company = [
  { href: '/about',   label: 'Nosotros' },
  { href: '/contact', label: 'Contacto' },
];
---

<footer class="pt-14 pb-0" style="background: #0f1729;">
  <div class="max-w-7xl mx-auto px-6 lg:px-8">

    <!-- Main grid -->
    <div class="grid grid-cols-1 md:grid-cols-4 gap-10 pb-12">

      <!-- Brand — col-span-2 -->
      <div class="md:col-span-2 space-y-5">
        <!-- Logo -->
        <a href="/" class="inline-block hover:opacity-80 transition-opacity" aria-label="EzEat inicio">
          <img src="/EZ eat (6).png" alt="EzEat" class="h-14 w-auto" />
        </a>

        <!-- Description -->
        <p class="text-white/50 font-body text-sm leading-relaxed max-w-sm">
          El primer sistema operativo inteligente para Hoteles, Restaurantes y Cafeterías que crece contigo.
        </p>

        <!-- Contact info -->
        <div class="space-y-2 text-sm font-body text-white/50">
          <div class="flex items-center gap-2">
            <span class="material-symbols-outlined text-base leading-none text-[#b0beff]">mail</span>
            <a href="mailto:hola@ezeat.com.mx" class="hover:text-white transition-colors">hola@ezeat.com.mx</a>
          </div>
          <div class="flex items-center gap-2">
            <span class="material-symbols-outlined text-base leading-none text-[#b0beff]">location_on</span>
            <span>CDMX · México</span>
          </div>
        </div>

        <!-- Social links -->
        <div class="flex gap-3 pt-1">
          <a href="https://www.linkedin.com/in/ez-eat-33841b408/" target="_blank" rel="noopener noreferrer" aria-label="LinkedIn"
            class="w-9 h-9 rounded-full bg-white/10 flex items-center justify-center text-white/50 hover:text-white hover:bg-white/20 transition-all">
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
              <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
            </svg>
          </a>
        </div>
      </div>

      <!-- Productos -->
      <div class="space-y-4">
        <h4 class="font-headline font-semibold text-white/80 text-sm">Productos</h4>
        <nav class="flex flex-col space-y-2.5">
          {products.map(link => (
            <a href={link.href}
              class="text-sm font-body text-white/50 hover:text-white hover:translate-x-0.5 transition-all duration-200 inline-block">
              {link.label}
            </a>
          ))}
        </nav>
      </div>

      <!-- Compañía -->
      <div class="space-y-4">
        <h4 class="font-headline font-semibold text-white/80 text-sm">Compañía</h4>
        <nav class="flex flex-col space-y-2.5">
          {company.map(link => (
            <a href={link.href}
              class="text-sm font-body text-white/50 hover:text-white hover:translate-x-0.5 transition-all duration-200 inline-block">
              {link.label}
            </a>
          ))}
        </nav>
      </div>

    </div>

    <!-- Bottom bar -->
    <div class="border-t border-white/10 py-6 flex flex-col sm:flex-row justify-between items-center gap-3">
      <p class="text-xs font-body text-white/40">
        © {currentYear} EzEat. Todos los derechos reservados.
      </p>
    </div>

  </div>
</footer>

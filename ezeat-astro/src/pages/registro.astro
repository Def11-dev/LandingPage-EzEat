---
import Layout from '../layouts/Layout.astro';
const API_URL = import.meta.env.PUBLIC_API_URL || 'https://api.ezeat.com.mx';
---

<Layout title="Registra tu restaurante — EzEat" description="Crea tu cuenta EzEat, elige tu plan y empieza a operar en minutos.">
  <main class="min-h-screen pt-28 pb-20 px-4 bg-surface-dim">
    <div class="max-w-2xl mx-auto">
      <div class="text-center mb-8">
        <span class="inline-block text-xs font-label font-bold tracking-widest uppercase text-primary bg-primary-container px-3 py-1 rounded-full mb-3">Registro</span>
        <h1 class="font-display text-3xl md:text-4xl font-extrabold text-secondary">Crea tu restaurante</h1>
        <p class="text-on-surface-variant mt-2">Elige tu plan, paga y empieza a operar en minutos. Tu sitio queda en <span class="font-mono font-semibold text-primary">tunegocio.ezeat.com.mx</span></p>
      </div>

      <form id="signup-form" class="bg-surface rounded-2xl border border-outline-variant/30 shadow-sm p-6 md:p-8 space-y-6">
        <div id="form-error" class="hidden p-3 rounded-xl bg-red-50 border border-red-200 text-sm text-red-700"></div>

        <!-- Negocio -->
        <div class="space-y-4">
          <h2 class="font-label font-bold text-secondary flex items-center gap-2"><span class="material-symbols-outlined text-primary">storefront</span> Tu negocio</h2>
          <div>
            <label class="block text-xs font-semibold uppercase tracking-wide text-on-surface-variant mb-1.5">Nombre del negocio</label>
            <input name="name" id="name" required placeholder="Tacos El Rey" class="w-full px-4 py-3 rounded-xl border border-outline-variant/50 focus:outline-none focus:ring-2 focus:ring-primary/40 focus:border-primary" />
          </div>
          <div>
            <label class="block text-xs font-semibold uppercase tracking-wide text-on-surface-variant mb-1.5">Tu subdominio (se genera solo)</label>
            <div class="flex items-center">
              <input name="slug" id="slug" required readonly tabindex="-1" placeholder="tunegocio" class="w-full px-4 py-3 rounded-l-xl border border-outline-variant/50 bg-surface-dim text-on-surface font-semibold cursor-default lowercase" />
              <span class="px-3 py-3 border border-l-0 border-outline-variant/50 rounded-r-xl bg-surface-dim text-on-surface-variant text-sm whitespace-nowrap">.ezeat.com.mx</span>
            </div>
            <p id="slug-status" class="text-xs mt-1.5 h-4"></p>
            <div id="slug-alts" class="hidden mt-1">
              <p class="text-xs text-on-surface-variant mb-1.5">Ese ya existe. Elige otro:</p>
              <div id="slug-alts-list" class="flex flex-wrap gap-2"></div>
            </div>
          </div>
        </div>

        <!-- Plan -->
        <div class="space-y-3">
          <h2 class="font-label font-bold text-secondary flex items-center gap-2"><span class="material-symbols-outlined text-primary">workspace_premium</span> Plan</h2>
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-3" id="plan-cards">
            <label class="plan-card cursor-pointer rounded-xl border-2 border-primary p-4 block" data-plan="tier1">
              <input type="radio" name="plan" value="tier1" class="hidden" checked />
              <div class="flex items-center justify-between">
                <span class="font-bold text-secondary">Operación Inteligente</span>
                <span class="material-symbols-outlined text-primary check">check_circle</span>
              </div>
              <p class="text-xs text-on-surface-variant mt-1">POS, cocina, kiosko, inventario, finanzas</p>
              <p class="text-xl font-extrabold text-secondary mt-2">$1,849<span class="text-xs font-normal text-on-surface-variant"> /mes</span></p>
            </label>
            <label class="plan-card cursor-pointer rounded-xl border-2 border-outline-variant/40 p-4 block" data-plan="tier2">
              <input type="radio" name="plan" value="tier2" class="hidden" />
              <div class="flex items-center justify-between">
                <span class="font-bold text-secondary">Inteligencia Total</span>
                <span class="material-symbols-outlined text-primary check opacity-0">check_circle</span>
              </div>
              <p class="text-xs text-on-surface-variant mt-1">Todo + IA, canales, contabilidad, predicción</p>
              <p class="text-xl font-extrabold text-secondary mt-2">$4,999<span class="text-xs font-normal text-on-surface-variant"> /mes</span></p>
            </label>
          </div>
        </div>

        <!-- Dueño -->
        <div class="space-y-4">
          <h2 class="font-label font-bold text-secondary flex items-center gap-2"><span class="material-symbols-outlined text-primary">person</span> Tu cuenta</h2>
          <div>
            <label class="block text-xs font-semibold uppercase tracking-wide text-on-surface-variant mb-1.5">Tu nombre</label>
            <input name="ownerName" placeholder="Juan Pérez" class="w-full px-4 py-3 rounded-xl border border-outline-variant/50 focus:outline-none focus:ring-2 focus:ring-primary/40 focus:border-primary" />
          </div>
          <div>
            <label class="block text-xs font-semibold uppercase tracking-wide text-on-surface-variant mb-1.5">Correo</label>
            <input name="ownerEmail" id="ownerEmail" type="email" required placeholder="tu@correo.com" class="w-full px-4 py-3 rounded-xl border border-outline-variant/50 focus:outline-none focus:ring-2 focus:ring-primary/40 focus:border-primary" />
          </div>
          <div>
            <label class="block text-xs font-semibold uppercase tracking-wide text-on-surface-variant mb-1.5">Contraseña</label>
            <input name="ownerPassword" type="password" required minlength="6" placeholder="mín. 6 caracteres" class="w-full px-4 py-3 rounded-xl border border-outline-variant/50 focus:outline-none focus:ring-2 focus:ring-primary/40 focus:border-primary" />
          </div>
        </div>

        <button type="submit" id="submit-btn" class="w-full bg-primary text-on-primary font-label font-bold py-4 rounded-xl hover:brightness-110 transition-all shadow-[0_4px_16px_rgba(43,73,243,0.25)] disabled:opacity-60 flex items-center justify-center gap-2">
          <span id="btn-text">Continuar al pago</span>
          <span class="material-symbols-outlined">arrow_forward</span>
        </button>
        <p class="text-xs text-center text-on-surface-variant">Pago seguro con Stripe. Cancela cuando quieras. Cobro mensual recurrente.</p>
      </form>
    </div>
  </main>

  <script define:vars={{ API_URL }}>
    const form = document.getElementById('signup-form');
    const slugInput = document.getElementById('slug');
    const slugStatus = document.getElementById('slug-status');
    const errorBox = document.getElementById('form-error');
    const btn = document.getElementById('submit-btn');
    const btnText = document.getElementById('btn-text');

    // Plan cards
    document.querySelectorAll('.plan-card').forEach((card) => {
      card.addEventListener('click', () => {
        document.querySelectorAll('.plan-card').forEach((c) => {
          c.classList.remove('border-primary'); c.classList.add('border-outline-variant/40');
          c.querySelector('.check').classList.add('opacity-0');
        });
        card.classList.add('border-primary'); card.classList.remove('border-outline-variant/40');
        card.querySelector('.check').classList.remove('opacity-0');
        card.querySelector('input').checked = true;
      });
    });

    // El subdominio se GENERA del nombre (no editable). Si existe, ofrece alternativas.
    const nameInput = document.getElementById('name');
    const altsBox = document.getElementById('slug-alts');
    const altsList = document.getElementById('slug-alts-list');
    const slugify = (s) => s.toLowerCase().normalize('NFD').replace(/[̀-ͯ]/g, '').replace(/[^a-z0-9]+/g, '-').replace(/^-+|-+$/g, '').slice(0, 40);
    let slugTimer;

    const isFree = async (v) => {
      try {
        const res = await fetch(`${API_URL}/api/signup/check-slug?slug=${encodeURIComponent(v)}`);
        const d = await res.json();
        return d.available === true;
      } catch { return false; }
    };

    const setSlug = (v) => {
      slugInput.value = v;
      slugStatus.textContent = '✓ Disponible: ' + v + '.ezeat.com.mx';
      slugStatus.className = 'text-xs mt-1.5 h-4 text-green-600';
    };

    const buildCandidates = (base) => {
      const out = [];
      for (let i = 2; i <= 4; i++) out.push(`${base}-${i}`);
      out.push(`${base}-mx`, `${base}-cdmx`, `${base}-oficial`);
      return out;
    };

    const styleChip = (el, active) => {
      el.className = 'px-3 py-1.5 rounded-full text-sm border transition-colors ' + (active ? 'border-primary bg-primary/10 text-primary font-semibold' : 'border-outline-variant/50 text-on-surface hover:border-primary');
    };

    const resolveSlug = async (base) => {
      altsList.replaceChildren();
      altsBox.classList.add('hidden');
      if (!base) { slugInput.value = ''; slugStatus.textContent = ''; return; }
      slugStatus.textContent = 'Verificando…'; slugStatus.className = 'text-xs mt-1.5 h-4 text-on-surface-variant';
      if (await isFree(base)) { setSlug(base); return; }

      // Ocupado → busca alternativas libres
      slugInput.value = '';
      slugStatus.textContent = '“' + base + '” ya existe';
      slugStatus.className = 'text-xs mt-1.5 h-4 text-red-600';
      const candidates = buildCandidates(base);
      const checks = await Promise.all(candidates.map(async c => ({ c, free: await isFree(c) })));
      const free = checks.filter(x => x.free).map(x => x.c).slice(0, 4);
      if (!free.length) return;
      setSlug(free[0]); // preselecciona la primera libre
      free.forEach((c, i) => {
        const b = document.createElement('button');
        b.type = 'button';
        b.textContent = c;
        styleChip(b, i === 0);
        b.addEventListener('click', () => {
          setSlug(c);
          [...altsList.children].forEach(el => styleChip(el, el === b));
        });
        altsList.appendChild(b);
      });
      altsBox.classList.remove('hidden');
    };

    nameInput.addEventListener('input', () => {
      const base = slugify(nameInput.value);
      clearTimeout(slugTimer);
      slugTimer = setTimeout(() => resolveSlug(base), 450);
    });

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      errorBox.classList.add('hidden');
      btn.disabled = true; btnText.textContent = 'Redirigiendo al pago...';
      const fd = new FormData(form);
      const body = Object.fromEntries(fd.entries());
      try {
        const res = await fetch(`${API_URL}/api/signup/checkout`, {
          method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(body),
        });
        const d = await res.json();
        if (!res.ok || !d.url) throw new Error(d.message || 'No se pudo iniciar el pago');
        window.location.href = d.url; // Stripe Checkout
      } catch (err) {
        errorBox.textContent = err.message; errorBox.classList.remove('hidden');
        btn.disabled = false; btnText.textContent = 'Continuar al pago';
      }
    });
  </script>
</Layout>

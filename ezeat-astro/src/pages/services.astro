---
import Layout from '../layouts/Layout.astro';

const blocks = [
  {
    id: 'front',
    category: 'Bloque 1',
    title: 'Operación Impecable',
    subtitle: 'Front of House',
    focus: 'Velocidad y experiencia del cliente.',
    icon: 'restaurant',
    features: [
      {
        id: 'pos',
        icon: 'point_of_sale',
        title: 'Transacciones sin fricción',
        desc: 'POS Básico o Inteligente según tu operación. El corazón de cada venta.',
        badge: 'Más Popular',
        badgeColor: 'bg-primary text-on-primary',
        tags: ['restaurantes', 'fastfood', 'hoteles'],
      },
      {
        id: 'kioscos',
        icon: 'smart_display',
        title: 'Reduce filas hasta un 60%',
        desc: 'Kioskos de autoservicio que venden solos y aumentan el ticket promedio.',
        badge: 'AI-Powered',
        badgeColor: 'bg-tertiary/10 text-tertiary',
        tags: ['fastfood', 'restaurantes'],
      },
      {
        id: 'menu',
        icon: 'menu_book',
        title: 'Tu carta siempre actualizada',
        desc: 'Menú digital sincronizado en tiempo real en cualquier pantalla o dispositivo.',
        badge: null,
        tags: ['restaurantes', 'hoteles', 'fastfood'],
      },
      {
        id: 'roomservice',
        icon: 'room_service',
        title: 'Pedidos directos a la habitación',
        desc: 'Room Service sin llamadas ni papeleos. El huésped ordena desde su móvil.',
        badge: 'Especial Hoteles',
        badgeColor: 'bg-secondary/10 text-secondary',
        tags: ['hoteles'],
      },
    ],
  },
  {
    id: 'back',
    category: 'Bloque 2',
    title: 'Control Total',
    subtitle: 'Back of House',
    focus: 'Eficiencia interna y ahorro de costos.',
    icon: 'admin_panel_settings',
    features: [
      {
        id: 'inventory',
        icon: 'inventory_2',
        title: 'Elimina mermas y robos hormiga',
        desc: 'Inventarios con IA: alertas automáticas y pronósticos de compra inteligentes.',
        badge: 'AI-Powered',
        badgeColor: 'bg-tertiary/10 text-tertiary',
        tags: ['restaurantes', 'hoteles', 'fastfood'],
      },
      {
        id: 'kds',
        icon: 'kitchen',
        title: 'Adiós a los tickets perdidos',
        desc: 'KDS (Pantallas de Cocina): flujo de órdenes claro, sin papel ni caos en la línea.',
        badge: null,
        tags: ['restaurantes', 'fastfood', 'hoteles'],
      },
      {
        id: 'staff',
        icon: 'badge',
        title: 'Tu equipo, en un estándar pro',
        desc: 'Gestión de personal: horarios, rendimiento y accesos desde un solo panel.',
        badge: 'BETA',
        badgeColor: 'bg-warning/10 text-warning',
        tags: ['restaurantes', 'hoteles'],
      },
    ],
  },
  {
    id: 'growth',
    category: 'Bloque 3',
    title: 'Crecimiento e Inteligencia',
    subtitle: 'Strategy',
    focus: 'Escalar el negocio con datos.',
    icon: 'trending_up',
    features: [
      {
        id: 'analytics',
        icon: 'monitoring',
        title: 'KPIs en tiempo real, multi-sucursal',
        desc: 'Analítica avanzada: ventas, margen, desempeño de productos y comportamiento de clientes.',
        badge: 'AI-Powered',
        badgeColor: 'bg-tertiary/10 text-tertiary',
        tags: ['restaurantes', 'hoteles', 'fastfood'],
      },
      {
        id: 'delivery',
        icon: 'delivery_dining',
        title: 'Un tablero para Rappi, Uber y propios',
        desc: 'Integración de delivery: centraliza tus pedidos externos y reduce comisiones con canal directo.',
        badge: 'Más Popular',
        badgeColor: 'bg-primary text-on-primary',
        tags: ['restaurantes', 'fastfood'],
      },
      {
        id: 'finance',
        icon: 'account_balance',
        title: 'Contabilidad automática desde tu operación',
        desc: 'Estados Financieros con IA: de transacciones a P&L en segundos, sin contadores de hojas de cálculo.',
        badge: 'Coming Soon',
        badgeColor: 'bg-outline/10 text-on-surface-variant',
        tags: ['restaurantes', 'hoteles', 'fastfood'],
      },
    ],
  },
];
---

<Layout
  title="Soluciones — EzEat"
  description="El ecosistema modular de EzEat: elige solo lo que necesitas para tu restaurante, hotel o fast food. Operación, control y crecimiento inteligente."
>

  <!-- ─── Hero ──────────────────────────────────────────────────── -->
  <section class="pt-16 pb-16 bg-surface relative overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-br from-surface to-surface-container-low opacity-50 pointer-events-none"></div>
    <div class="max-w-7xl mx-auto px-6 lg:px-8 relative z-10 text-center max-w-3xl mx-auto">
      <div class="inline-flex items-center gap-2 bg-surface-container-highest px-4 py-2 rounded-full mb-6" data-animate="fade-up">
        <span class="material-symbols-outlined text-primary text-base leading-none">extension</span>
        <span class="text-sm font-label font-medium text-on-surface">El Ecosistema Modular</span>
      </div>
      <h1 class="font-headline text-5xl md:text-6xl font-extrabold tracking-tight text-on-background leading-[1.05] mb-5" data-animate="fade-up">
        Arma tu operación <span class="text-primary">a la carta.</span>
      </h1>
      <p class="text-on-surface-variant text-xl font-body leading-relaxed mb-10" data-animate="fade-up">
        Sin paquetes inflados. Elige solo los módulos que tu negocio necesita hoy y agrega más conforme escalas.
      </p>

      <!-- Filter bar -->
      <div class="flex flex-wrap justify-center gap-3" id="filter-bar" data-animate="fade-up">
        {['Todas', 'Restaurantes', 'Hoteles', 'Fast Food'].map((f, i) => (
          <button
            data-filter={f === 'Todas' ? 'all' : f.toLowerCase().replace(' ', '')}
            class={`filter-btn px-5 py-2.5 rounded-full font-label font-medium text-sm transition-all duration-200 border ${i === 0 ? 'bg-primary text-on-primary border-primary shadow-[0_4px_12px_rgba(0,44,163,0.2)]' : 'bg-surface-container-lowest text-on-surface border-outline-variant/20 hover:border-primary/40 hover:bg-surface-container-low'}`}
          >
            {f}
          </button>
        ))}
      </div>
    </div>
  </section>

  <!-- ─── Feature Blocks ───────────────────────────────────────── -->
  <section class="pb-24 bg-surface">
    <div class="max-w-7xl mx-auto px-6 lg:px-8 space-y-20">
      {blocks.map(block => (
        <div class="space-y-8" data-block={block.id}>
          <!-- Block header -->
          <div class="flex flex-col sm:flex-row sm:items-center gap-4 pb-4 border-b border-outline-variant/15" data-animate="fade-up">
            <div class="flex items-center gap-4">
              <div class="w-12 h-12 bg-primary/8 rounded-xl flex items-center justify-center text-primary">
                <span class="material-symbols-outlined text-2xl leading-none">{block.icon}</span>
              </div>
              <div>
                <p class="text-xs font-label font-bold text-primary uppercase tracking-wider">{block.category}</p>
                <h2 class="font-headline text-2xl font-bold text-on-background">{block.title} <span class="text-on-surface-variant font-normal text-lg">— {block.subtitle}</span></h2>
              </div>
            </div>
            <p class="text-on-surface-variant font-body text-sm sm:ml-auto italic">{block.focus}</p>
          </div>

          <!-- Feature cards -->
          <div class="grid sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6" data-stagger>
            {block.features.map(f => (
              <div
                class="feature-card flex flex-col bg-surface-container-lowest rounded-xl border border-outline-variant/10 p-6 hover:border-primary/30 hover:shadow-[0_8px_24px_rgba(26,27,36,0.07)] hover:-translate-y-1 transition-all duration-300 group relative"
                data-tags={f.tags.join(',')}
              >
                {f.badge && (
                  <span class={`absolute top-4 right-4 text-xs font-label font-bold px-2.5 py-1 rounded-full ${f.badgeColor}`}>
                    {f.badge}
                  </span>
                )}
                <div class="w-12 h-12 bg-primary/8 rounded-xl flex items-center justify-center text-primary mb-5 group-hover:bg-primary/15 transition-colors">
                  <span class="material-symbols-outlined text-2xl leading-none">{f.icon}</span>
                </div>
                <h3 class="font-headline font-bold text-base text-on-background mb-2 pr-16">{f.title}</h3>
                <p class="font-body text-on-surface-variant text-sm leading-relaxed flex-grow">{f.desc}</p>
                <a href="/contact" class="mt-5 inline-flex items-center gap-1 text-xs font-label font-semibold text-primary hover:gap-2 transition-all">
                  Agregar al plan <span class="material-symbols-outlined text-sm leading-none">add_circle</span>
                </a>
              </div>
            ))}
          </div>
        </div>
      ))}
    </div>
  </section>

  <!-- ─── Bottom CTA Banner ─────────────────────────────────────── -->
  <section class="py-20 bg-primary">
    <div class="max-w-4xl mx-auto px-6 lg:px-8 text-center" data-animate="fade-up">
      <span class="material-symbols-outlined text-on-primary/60 text-5xl block mb-6 leading-none">auto_awesome</span>
      <h2 class="text-3xl md:text-4xl font-headline font-bold text-on-primary mb-4">
        ¿No sabes por dónde empezar?
      </h2>
      <p class="text-on-primary/85 font-body mb-8 text-lg max-w-xl mx-auto">
        Deja que nuestra IA diseñe tu configuración ideal basada en el perfil de tu negocio.
      </p>
      <a href="/" class="bg-surface-container-lowest text-primary px-8 py-4 rounded-lg font-label font-medium text-lg shadow-lg hover:bg-surface-container-low hover:-translate-y-px transition-all duration-200 inline-flex items-center gap-2">
        <span class="material-symbols-outlined text-xl leading-none">restart_alt</span>
        Volver al Diagnóstico
      </a>
    </div>
  </section>

</Layout>

<script>
  const filterBtns = document.querySelectorAll<HTMLButtonElement>('.filter-btn');
  const featureCards = document.querySelectorAll<HTMLElement>('.feature-card');

  filterBtns.forEach(btn => {
    btn.addEventListener('click', () => {
      const filter = btn.dataset.filter!;

      // Update active button style
      filterBtns.forEach(b => {
        b.classList.remove('bg-primary', 'text-on-primary', 'border-primary', 'shadow-[0_4px_12px_rgba(0,44,163,0.2)]');
        b.classList.add('bg-surface-container-lowest', 'text-on-surface', 'border-outline-variant/20');
      });
      btn.classList.add('bg-primary', 'text-on-primary', 'border-primary', 'shadow-[0_4px_12px_rgba(0,44,163,0.2)]');
      btn.classList.remove('bg-surface-container-lowest', 'text-on-surface', 'border-outline-variant/20');

      // Show/hide cards
      featureCards.forEach(card => {
        const tags = card.dataset.tags?.split(',') ?? [];
        const matches = filter === 'all' || tags.includes(filter);
        card.style.display = matches ? '' : 'none';
        card.style.opacity = matches ? '1' : '0';
      });
    });
  });
</script>

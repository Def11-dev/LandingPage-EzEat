---
import Layout from '../layouts/Layout.astro';

const sections = [
  {
    num: '01',
    id: 'operacion',
    label: 'Operación',
    title: 'Lo que sucede frente al cliente y en cocina.',
    modules: [
      {
        icon: 'point_of_sale',
        name: 'POS Básico',
        desc: 'Una interfaz limpia para cobrar y mandar a cocina. Ideal para el dueño que está ahí todo el día y solo quiere que el negocio camine.',
        price: 'Desde $349',
        priceNote: null,
        status: 'listo', ia: false,
      },
      {
        icon: 'tablet_android',
        name: 'POS Inteligente',
        desc: 'Permisos por usuario: el cajero solo cobra; el gerente hace descuentos, cancelaciones y ve el arqueo en vivo. Conectado con Inventarios y Analítica IA.',
        price: 'Desde $989',
        priceNote: null,
        status: 'listo', ia: true,
      },
      {
        icon: 'credit_card',
        name: 'Integración de Pagos',
        desc: 'Procesa cobros directamente desde el POS sin terminales aparte ni conciliaciones manuales.',
        price: '≈ 4% por transacción',
        priceNote: null,
        status: 'listo', ia: false,
      },
      {
        icon: 'smart_display',
        name: 'Kioskos de Autoservicio',
        desc: 'Pedidos autogestionados por el cliente con upsell visual integrado.',
        price: 'Desde $489',
        priceNote: '+ hardware',
        status: 'listo', ia: false,
      },
      {
        icon: 'language',
        name: 'Pedidos en Línea',
        desc: 'Menú digital, carrito y checkout propios. Todo lo que vendes se queda contigo.',
        price: 'Desde $349',
        priceNote: null,
        status: 'listo', ia: false,
      },
      {
        icon: 'kitchen',
        name: 'KDS — Pantallas de Cocina',
        desc: 'El corazón del ecosistema EzEat. Sincroniza órdenes de POS, kioskos, comanda digital y delivery en una sola pantalla.',
        price: 'Desde $349',
        priceNote: '+ hardware',
        status: 'listo', ia: false,
      },
      {
        icon: 'stylus_note',
        name: 'Comanda Digital de Meseros',
        desc: "Movilidad total para el equipo de piso. Al dar 'Enviar', la orden aparece instantáneamente en cocina.",
        price: 'Desde $150',
        priceNote: null,
        status: 'beta', ia: false,
      },
      {
        icon: 'room_service',
        name: 'Room Service Hotelero',
        desc: 'Menú digital del hotel, pago directo o cargo a cuenta y conexión al PMS.',
        price: 'Desde $2,899',
        priceNote: 'plan completo hotel',
        status: 'beta', ia: false,
      },
    ],
  },
  {
    num: '02',
    id: 'control',
    label: 'Control',
    title: 'Lo que protege tus márgenes y procesos.',
    modules: [
      {
        icon: 'inventory_2',
        name: 'Control de Inventarios',
        desc: 'Predice mermas, sugiere recetas y optimiza tu costo de venta. Incluye Compras y Proveedores.',
        price: 'Desde $749',
        priceNote: 'incluye Compras',
        status: 'beta', ia: true,
      },
      {
        icon: 'shopping_cart',
        name: 'Compras y Proveedores',
        desc: 'Órdenes automáticas, comparación de precios y kardex digital. Empaquetado junto a Inventarios.',
        price: 'Desde $749',
        priceNote: 'incluye Inventarios',
        status: 'beta', ia: true,
      },
      {
        icon: 'bar_chart',
        name: 'Analítica Avanzada',
        desc: 'Alertas inteligentes, comparativas y forecast con IA por canal de venta.',
        price: 'Desde $449',
        priceNote: null,
        status: 'beta', ia: true,
      },
      {
        icon: 'people',
        name: 'Gestión de Personal',
        desc: 'Asesoramiento 24/7 para resolver dudas y operar el sistema en cualquier sucursal.',
        price: 'Desde $49',
        priceNote: 'varía por sucursal',
        status: 'beta', ia: false,
      },
      {
        icon: 'receipt_long',
        name: 'Facturación Electrónica',
        desc: 'Resuelve uno de los grandes dolores de la industria con facturación 100% automatizada.',
        price: 'Desde $329',
        priceNote: null,
        status: 'roadmap', ia: false,
      },
      {
        icon: 'description',
        name: 'Estados Financieros con IA',
        desc: 'Genera estados financieros a partir de datos en bruto, con explicaciones automáticas por línea.',
        price: 'Desde $1,150',
        priceNote: null,
        status: 'roadmap', ia: true,
      },
    ],
  },
  {
    num: '03',
    id: 'crecimiento',
    label: 'Crecimiento',
    title: 'Lo que impulsa tus ventas y la lealtad.',
    modules: [
      {
        icon: 'favorite',
        name: 'Sistema de Lealtad',
        desc: 'Convierte visitantes en clientes recurrentes con cupones, niveles y promociones automáticas.',
        price: 'Desde $345',
        priceNote: null,
        status: 'listo', ia: false,
      },
      {
        icon: 'delivery_dining',
        name: 'Integración de Delivery',
        desc: 'Centraliza todas tus apps de delivery sin pagar comisiones extra de software.',
        price: 'Desde $549',
        priceNote: null,
        status: 'beta', ia: false,
      },
      {
        icon: 'chat',
        name: 'Pedidos por WhatsApp con IA',
        desc: 'Chatbot conversacional que toma pedidos completos por WhatsApp y los envía a cocina.',
        price: 'Desde $949',
        priceNote: 'o por conversión',
        status: 'roadmap', ia: true,
      },
      {
        icon: 'event',
        name: 'Sistema de Reservaciones',
        desc: 'Optimiza la rotación de mesas y reduce ausencias con confirmaciones automáticas.',
        price: 'Desde $329',
        priceNote: null,
        status: 'roadmap', ia: false,
      },
      {
        icon: 'format_list_numbered',
        name: 'Gestión de Colas',
        desc: 'Cuando no hay mesas disponibles, el cliente se anota y le avisas cuando es su turno.',
        price: 'Desde $349',
        priceNote: 'hasta cierto volumen',
        status: 'roadmap', ia: false,
      },
      {
        icon: 'call',
        name: 'Pedidos por Llamada con IA',
        desc: 'Los pedidos llegan automáticamente al KDS sin que tu equipo levante el teléfono.',
        price: 'Desde $889',
        priceNote: null,
        status: 'roadmap', ia: true,
      },
    ],
  },
  {
    num: '04',
    id: 'proximamente',
    label: 'Próximamente',
    title: 'El futuro del ecosistema EzEat.',
    modules: [
      {
        icon: 'smartphone',
        name: 'EzEat App (Marketplace)',
        desc: 'Nuestro destino final: una app única donde tus clientes descubren tu negocio.',
        price: 'gratis',
        priceNote: null,
        status: 'roadmap', ia: false,
      },
      {
        icon: 'pedal_bike',
        name: 'EzEat Delivery',
        desc: 'Los repartidores cobran 100% del envío, calibrado por calificación. Conectado a EzEat App, con visión a Last Mile Delivery.',
        price: 'modelo por envío',
        priceNote: null,
        status: 'roadmap', ia: false,
      },
    ],
  },
];

const statusMeta: Record<string, { label: string; cls: string; icon: string }> = {
  listo:   { label: 'Listo',        cls: 'bg-[#dcfce7] text-[#16a34a]',  icon: 'check_circle' },
  beta:    { label: 'Beta / Pronto', cls: 'bg-[#fff7ed] text-[#ea580c]', icon: 'schedule' },
  roadmap: { label: 'Roadmap',      cls: 'bg-[#eff6ff] text-[#2563eb]',  icon: 'rocket_launch' },
};
---

<Layout
  title="Soluciones — EzEat"
  description="El ecosistema modular de EzEat: elige solo lo que necesitas para tu restaurante, hotel o fast food."
>

  <!-- Hero -->
  <section class="pt-16 pb-20 flex items-center justify-center" style="background: linear-gradient(135deg, #0f1729 0%, #141d3d 50%, #1a2450 100%);">
    <div class="max-w-3xl mx-auto px-6 text-center" data-animate="fade-up">
      <div class="inline-flex items-center gap-2 bg-white/10 border border-white/20 px-4 py-2 rounded-full mb-6">
        <span class="material-symbols-outlined text-[#b0beff] text-base leading-none">auto_awesome</span>
        <span class="text-sm font-label font-medium text-white/90">Catálogo modular</span>
      </div>
      <h1 class="font-headline text-5xl md:text-6xl font-extrabold tracking-tight text-white leading-[1.05] mb-5">
        Una solución para cada <span class="text-[#b0beff]">momento de tu operación</span>
      </h1>
      <p class="text-lg text-white/70 font-body max-w-xl mx-auto">
        Operación, control y crecimiento. Activa módulos individualmente y combínalos como tu negocio lo necesite.
      </p>
    </div>
  </section>

  <!-- Sections -->
  <section class="pb-24 bg-surface-container-low">
    <div class="max-w-7xl mx-auto px-6 lg:px-8 pt-16 space-y-20">
      {sections.map(sec => {
        return (
          <div id={sec.id} data-animate="fade-up">
            <!-- Section header -->
            <div class="mb-8">
              <p class="text-primary font-label font-bold text-sm tracking-widest uppercase mb-2">{sec.num} · {sec.label.toUpperCase()}</p>
              <h2 class="font-headline text-3xl md:text-4xl font-bold text-on-background">{sec.title}</h2>
            </div>

            <!-- Module cards -->
            <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5" data-stagger>
              {sec.modules.map(mod => {
                const sm = statusMeta[mod.status];
                return (
                  <div class="bg-white rounded-2xl border border-outline-variant/15 p-6 flex flex-col hover:shadow-[0_8px_32px_rgba(26,27,36,0.08)] hover:-translate-y-1 transition-all duration-300">
                    <!-- Top: icon + badges -->
                    <div class="flex items-start justify-between mb-4">
                      <div class="w-12 h-12 bg-primary rounded-xl flex items-center justify-center shrink-0">
                        <span class="material-symbols-outlined text-white text-2xl leading-none">{mod.icon}</span>
                      </div>
                      <div class="flex flex-col items-end gap-1.5">
                        <span class={`inline-flex items-center gap-1 text-[11px] font-label font-semibold px-2.5 py-1 rounded-full ${sm.cls}`}>
                          <span class="material-symbols-outlined text-[11px] leading-none">{sm.icon}</span>
                          {sm.label}
                        </span>
                        {mod.ia && (
                          <span class="inline-flex items-center gap-1 text-[11px] font-label font-semibold px-2.5 py-1 rounded-full bg-[#eff6ff] text-primary">
                            <span class="material-symbols-outlined text-[11px] leading-none">auto_awesome</span>
                            IA
                          </span>
                        )}
                      </div>
                    </div>

                    <!-- Name + desc -->
                    <h3 class="font-headline font-bold text-on-background text-lg mb-2">{mod.name}</h3>
                    <p class="font-body text-on-surface-variant text-sm leading-relaxed flex-1">{mod.desc}</p>

                    <!-- Price + CTA -->
                    <div class="flex items-end justify-between mt-5 pt-4 border-t border-outline-variant/10">
                      <div>
                        {mod.price === 'gratis' || mod.price === 'modelo por envío' ? (
                          <p class="text-sm font-headline font-bold text-on-background">{mod.price}</p>
                        ) : (
                          <p class="text-sm font-body text-on-surface">
                            Desde <span class="font-headline font-bold text-on-background">{mod.price}</span> <span class="text-on-surface-variant">/mes</span>
                          </p>
                        )}
                        {mod.priceNote && <p class="text-xs text-on-surface-variant font-body mt-0.5">{mod.priceNote}</p>}
                      </div>
                      <a href="/contact" class="text-sm font-label font-semibold text-primary hover:gap-2 flex items-center gap-1 transition-all">
                        Cotizar <span class="material-symbols-outlined text-base leading-none">arrow_forward</span>
                      </a>
                    </div>
                  </div>
                );
              })}
            </div>
          </div>
        );
      })}
    </div>
  </section>

  <!-- Bottom CTA -->
  <section class="py-16 bg-surface-container-low">
    <div class="max-w-7xl mx-auto px-6 lg:px-8" data-animate="fade-up">
      <div class="rounded-2xl px-10 py-14 text-center" style="background: linear-gradient(135deg, #0f1729 0%, #141d3d 60%, #1a2450 100%);">
        <h2 class="text-3xl md:text-4xl font-headline font-bold text-white mb-3">
          ¿No sabes por dónde empezar?
        </h2>
        <p class="text-white/60 font-body mb-8 text-base max-w-md mx-auto">
          Te ayudamos a armar tu stack ideal en una sesión sin costo.
        </p>
        <a href="/contact" class="inline-flex items-center gap-2 bg-primary text-white px-8 py-4 rounded-xl font-label font-semibold text-base shadow-[0_8px_24px_rgba(43,73,243,0.4)] hover:brightness-110 hover:-translate-y-px transition-all duration-200">
          Hablar con un experto
          <span class="material-symbols-outlined text-xl leading-none">arrow_forward</span>
        </a>
      </div>
    </div>
  </section>

</Layout>

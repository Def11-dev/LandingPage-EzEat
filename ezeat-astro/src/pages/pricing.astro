---
import Layout from '../layouts/Layout.astro';

const tiers = [
  {
    id: 'operacion',
    name: 'Operación Inteligente',
    tagline: 'El cerebro completo de tu restaurante.',
    description: 'Ventas, cocina, inventarios, equipo y finanzas conectados en un solo sistema.',
    price: '$1,849',
    unit: 'MXN /mes',
    popular: false,
    includesFrom: null,
    groups: [
      {
        label: 'Ventas y atención al cliente',
        items: [
          'Tu propia tienda en línea con pagos seguros con tarjeta',
          'Punto de Venta (POS) ágil',
          'Menú digital 100% personalizable (categorías, tamaños, extras)',
          'Kiosco de auto-pedido',
          'App instalable en el celular, sin tiendas de aplicaciones',
          'Motor de ofertas y cupones (2x1, descuentos, regalos)',
          'Programa de Lealtad y Recompensas',
        ],
      },
      {
        label: 'Cocina y servicio',
        items: [
          'Pantallas digitales de cocina con historial y tiempos de preparación',
          'Organización automática por estaciones (parrilla, barra, etc.)',
          'Comandero móvil para meseros, con división de cuenta',
          'Reservaciones y control de mesas',
          'Avisos automáticos al cliente por correo',
        ],
      },
      {
        label: 'Inventarios y finanzas',
        items: [
          'Control estricto de inventario con alertas de stock mínimo',
          'Descuento automático por receta',
          'Rastreador de gastos operativos',
          'Gráficos financieros y de ventas',
          'Listo para Facturación Electrónica SAT (Próximamente)',
        ],
      },
      {
        label: 'Equipo y sucursales',
        items: [
          'Control multi-sucursal con dashboard comparativo',
          'Roles y permisos por empleado (inicio de sesión con correo o Google)',
          'Registro de asistencia digital',
          'Gestión inteligente de repartos (zonas, tarifas, horarios)',
          'Compatibilidad nativa con impresoras térmicas',
        ],
      },
    ],
    cta: 'Empezar con Operación Inteligente',
    ctaHref: '/contact',
  },
  {
    id: 'inteligencia',
    name: 'Inteligencia Total',
    tagline: 'Todo lo de Operación Inteligente, más la IA que predice, automatiza y decide por ti.',
    description: 'Para negocios listos para dejar que la Inteligencia Artificial tome el control operativo del día a día.',
    price: '$4,999',
    unit: 'MXN /mes',
    popular: true,
    includesFrom: 'Operación Inteligente',
    groups: [
      {
        label: 'Inteligencia Artificial y automatización',
        items: [
          'Control de filas de espera',
          'Directorio inteligente de proveedores',
          'Reportes contables descargables',
          'Comandero por voz para meseros',
          'Atención automática de pedidos por WhatsApp y llamadas',
          'Asesor financiero con IA',
          'Asistente virtual de consulta',
          'Resúmenes diarios en tu correo',
          'Feed de decisiones: sugerencias automáticas para vender más',
          'Piloto automático: el sistema ejecuta las reglas por ti',
          'Estudio de competencia local',
          'Creador instantáneo de menús con una foto',
        ],
      },
    ],
    cta: 'Empezar con Inteligencia Total',
    ctaHref: '/contact',
  },
];
---

<Layout
  title="Precios — EzEat"
  description="Elige el plan EzEat que mejor se adapta a tu operación. Desde Food Trucks hasta corporativos multi-marca."
>

  <!-- Hero -->
  <section class="pt-16 pb-16 flex items-center justify-center" style="background: linear-gradient(135deg, #0f1729 0%, #141d3d 50%, #1a2450 100%);">
    <div class="max-w-3xl mx-auto px-6 text-center" data-animate="fade-up">
      <div class="inline-flex items-center gap-2 bg-white/10 border border-white/20 px-4 py-2 rounded-full mb-6">
        <span class="material-symbols-outlined text-[#b0beff] text-base leading-none">auto_awesome</span>
        <span class="text-sm font-label font-medium text-white/90">Precios transparentes</span>
      </div>
      <h1 class="font-headline text-5xl md:text-6xl font-bold tracking-tight text-white leading-[1.05] mb-5">
        Dos planes. <span class="text-[#b0beff]">Todo lo que necesitas.</span>
      </h1>
      <p class="font-body text-lg text-white/70 max-w-xl mx-auto mb-8">
        Empieza con la operación completa de tu restaurante, o súmale la Inteligencia Artificial que predice, automatiza y decide por ti.
      </p>
      <!-- Tab switcher -->
      <div class="inline-flex items-center bg-white/10 border border-white/15 rounded-full p-1 gap-1">
        <span class="px-5 py-2 rounded-full bg-white font-label font-medium text-sm text-on-surface cursor-default">
          Planes preconfigurados
        </span>
        <a href="/pricing/alacarta"
          class="px-5 py-2 rounded-full font-label font-medium text-sm text-white/60 hover:text-white transition-colors">
          A la carta
        </a>
      </div>
    </div>
  </section>

  <!-- ROI callout -->
  <section class="py-10 bg-surface-container-low border-b border-outline-variant/10">
    <div class="max-w-5xl mx-auto px-6 lg:px-8">
      <div class="grid md:grid-cols-3 gap-0 divide-y md:divide-y-0 md:divide-x divide-outline-variant/15 text-center">
        <div class="py-6 px-8">
          <p class="font-headline text-3xl font-bold text-primary mb-2">35%</p>
          <p class="font-body text-sm text-on-surface-variant leading-relaxed">de los insumos se pierden en mermas en el restaurante promedio cada mes</p>
        </div>
        <div class="py-6 px-8">
          <p class="font-headline text-3xl font-bold text-primary mb-2">$4–$7</p>
          <p class="font-body text-sm text-on-surface-variant leading-relaxed">en ventas necesitas generar para recuperar cada peso de comida tirada</p>
        </div>
        <div class="py-6 px-8">
          <p class="font-headline text-3xl font-bold text-[#16a34a] mb-2">-25–30%</p>
          <p class="font-body text-sm text-on-surface-variant leading-relaxed">de merma reducida con EzEat gracias a IA predictiva nativa desde el primer mes</p>
        </div>
      </div>
      <p class="text-center font-body text-sm text-on-surface-variant mt-4 italic">
        La pregunta no es cuánto cuesta EzEat. La pregunta es cuánto te está costando no tenerlo.
      </p>
    </div>
  </section>

  <!-- Plans -->
  <section class="pb-24 bg-surface">
    <div class="max-w-6xl mx-auto px-6 lg:px-8">
      <div class="grid md:grid-cols-2 gap-8 items-start" data-stagger>
        {tiers.map(tier => (
          <div class={`relative bg-white rounded-2xl border flex flex-col overflow-hidden shadow-sm ${tier.popular ? 'border-primary shadow-[0_0_0_2px_#2b49f3]' : 'border-outline-variant/20'}`}>

            {tier.popular && (
              <div class="flex justify-center -mt-px">
                <div class="inline-flex items-center gap-1.5 bg-primary text-on-primary text-xs font-label font-semibold px-4 py-1.5 rounded-b-xl">
                  <span class="material-symbols-outlined text-sm leading-none fill">auto_awesome</span>
                  Con Inteligencia Artificial
                </div>
              </div>
            )}

            <div class="p-8 md:p-10 flex-1 flex flex-col">
              <!-- Header -->
              <h2 class="font-headline text-2xl font-bold text-on-background">{tier.name}</h2>
              <p class="text-primary font-body text-sm font-medium mt-1">{tier.tagline}</p>
              <p class="text-on-surface-variant font-body text-sm mt-3 leading-relaxed">{tier.description}</p>

              <!-- Price -->
              <div class="mt-6 mb-6">
                <span class="font-headline font-extrabold text-5xl text-on-background">{tier.price}</span>
                <span class="text-on-surface-variant font-body text-sm ml-1">{tier.unit}</span>
              </div>

              <!-- Includes-from banner -->
              {tier.includesFrom && (
                <div class="flex items-center gap-2 mb-6 bg-primary/5 border border-primary/15 rounded-lg px-4 py-3">
                  <span class="material-symbols-outlined text-primary text-lg leading-none">check_circle</span>
                  <p class="text-sm font-body text-on-background font-medium">Incluye todo lo de {tier.includesFrom}, más:</p>
                </div>
              )}

              <!-- Feature groups -->
              <div class="space-y-6 flex-1">
                {tier.groups.map(group => (
                  <div>
                    <p class="text-[10px] font-label font-semibold tracking-widest text-primary uppercase mb-3">{group.label}</p>
                    <ul class="grid sm:grid-cols-2 gap-x-4 gap-y-2.5">
                      {group.items.map(item => (
                        <li class="flex items-start gap-2 text-sm font-body text-on-surface leading-snug">
                          <span class="material-symbols-outlined text-primary text-base leading-none fill mt-0.5 shrink-0">check_circle</span>
                          {item}
                        </li>
                      ))}
                    </ul>
                  </div>
                ))}
              </div>
            </div>

            <!-- CTA -->
            <div class="px-8 md:px-10 pb-8 md:pb-10">
              <a
                href={tier.ctaHref}
                class={`w-full font-label font-medium py-3.5 rounded-lg flex items-center justify-center gap-2 transition-all duration-200 text-sm ${tier.popular ? 'bg-primary text-on-primary hover:brightness-110' : 'border border-outline-variant/30 text-on-surface hover:border-primary/40 hover:text-primary'}`}
              >
                {tier.cta}
                <span class="material-symbols-outlined text-base leading-none">arrow_forward</span>
              </a>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- A la carta -->
  <section class="py-12 bg-surface border-t border-outline-variant/10">
    <div class="max-w-xl mx-auto px-6 text-center" data-animate="fade-up">
      <p class="text-on-surface-variant font-body text-base mb-5">¿Necesitas algo distinto? Configura módulo por módulo.</p>
      <a href="/pricing/alacarta"
        class="inline-flex items-center gap-2 border border-outline-variant/30 text-on-surface font-label font-medium px-7 py-3 rounded-lg hover:border-primary/40 hover:text-primary transition-all duration-200">
        Ir al modo A la carta
        <span class="material-symbols-outlined text-base leading-none">arrow_forward</span>
      </a>
    </div>
  </section>

</Layout>

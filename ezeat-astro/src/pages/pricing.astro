---
import Layout from '../layouts/Layout.astro';

const heroImg = 'https://lh3.googleusercontent.com/aida-public/AB6AXuD2Xzu8LB8ZjSTS6ylGPlyQSkHD4gE-QNho_TLpv2jd1hZwZ8NJZQJvl2o7TEtbdHu1yUglHNtg7r-nJc16hAKVc0Aym81dPP38XoyY-Whd3aNB0HHsf0aEQ9skuAkNM4k9eRNbguIVC0e5gRh7sm2Q4jjOPbtVZc0v18qlisXZgUPcSkdhSov_LfAIoRQhmNxllVgZo4_NlYGTSsmPFSGtxRp5otTaCq277hxdKjzMpRi27nBMTo1LODk3T9kZzIZyJfbKe_ZVcYoF';

const plans = [
  {
    name: 'Starter',
    price: '$499',
    period: '/mo',
    desc: 'For growing teams requiring essential dining management.',
    features: [
      'Up to 500 active users',
      'Standard reporting dashboard',
      'Email support (24h SLA)',
      'Basic vendor integration',
    ],
    cta: 'Get Started',
    ctaHref: '/contact',
    highlight: false,
  },
  {
    name: 'Professional',
    price: '$999',
    period: '/mo',
    desc: 'Comprehensive tools for mid-market corporate campuses.',
    features: [
      'Up to 2,500 active users',
      'Advanced Analytics & Insights',
      'Priority Support (4h SLA)',
      'Custom Branding options',
      'Multi-location management',
    ],
    cta: 'Start Free Trial',
    ctaHref: '/contact',
    highlight: true,
    badge: 'Most Popular',
  },
  {
    name: 'Enterprise',
    price: 'Custom',
    period: '',
    desc: 'Bespoke architecture for global organizational networks.',
    features: [
      'Unlimited users',
      'Dedicated Success Manager',
      '24/7 Phone & Email Support',
      'Full API Access & Custom Integrations',
      'On-premise deployment options',
    ],
    cta: 'Contact Sales',
    ctaHref: '/contact',
    highlight: false,
  },
];

const faqs = [
  {
    q: 'How long does Enterprise implementation take?',
    a: 'Implementation timelines vary based on architectural complexity, but typically range from 4 to 8 weeks. Our dedicated deployment team works directly with your IT and facilities departments to ensure a seamless rollout.',
  },
  {
    q: 'What level of custom branding is available?',
    a: 'The Professional and Enterprise tiers offer extensive whitelabeling. You can customize the app icon, primary colorways, typography, and splash screens to match your corporate identity completely.',
  },
  {
    q: 'Do you offer volume discounts for large campuses?',
    a: 'Yes. Our Custom Enterprise plans are designed to scale economically. Contact our sales team to discuss tiered pricing based on active user volume and multi-site deployments.',
  },
  {
    q: 'Is there a free trial available?',
    a: 'The Professional plan includes a 14-day free trial with full feature access. No credit card required to start.',
  },
];
---

<Layout
  title="Pricing — Ezeat"
  description="Flexible enterprise pricing plans for Ezeat. Choose from Starter, Professional, or Enterprise tiers tailored to your scale."
>

  <!-- ─── Hero ──────────────────────────────────────────────────── -->
  <section class="pt-16 pb-24 bg-surface relative overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-br from-surface to-surface-container-low opacity-50 pointer-events-none"></div>
    <div class="max-w-7xl mx-auto px-6 lg:px-8 relative z-10">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-14 items-center">

        <div class="max-w-xl space-y-8" data-animate="slide-right">
          <div class="inline-flex items-center gap-2 bg-surface-container-highest px-4 py-2 rounded-full">
            <span class="material-symbols-outlined text-primary text-base leading-none">payments</span>
            <span class="text-sm font-label font-medium text-on-surface">Transparent Pricing</span>
          </div>
          <h1 class="font-headline text-5xl md:text-6xl font-bold tracking-tight text-on-background leading-[1.05]">
            Flexible{' '}
            <span class="text-primary">Enterprise</span>{' '}
            Pricing
          </h1>
          <p class="font-body text-xl text-on-surface-variant leading-relaxed">
            Scale your corporate dining experience with transparent, predictable pricing. Choose the plan that aligns with your architectural growth.
          </p>
          <div class="flex flex-col sm:flex-row gap-4">
            <a
              href="/contact"
              class="bg-primary text-on-primary px-8 py-4 rounded-lg font-label font-medium shadow-[0_8px_32px_rgba(0,44,163,0.2)] hover:bg-primary-container hover:-translate-y-px transition-all duration-200 flex justify-center items-center gap-2"
            >
              Contact Sales
              <span class="material-symbols-outlined text-xl leading-none">arrow_forward</span>
            </a>
            <button class="border border-outline-variant/30 text-primary bg-surface px-8 py-4 rounded-lg font-label font-medium hover:bg-surface-container-low transition-colors">
              View Full Feature Matrix
            </button>
          </div>
        </div>

        <div class="relative h-[380px]" data-animate="slide-left">
          <div class="w-full h-full rounded-xl overflow-hidden shadow-[0_24px_48px_rgba(26,27,36,0.09)]">
            <img
              src={heroImg}
              alt="Modern corporate office with architectural precision"
              class="w-full h-full object-cover"
              loading="eager"
            />
            <div class="absolute inset-0 bg-gradient-to-tr from-primary/15 to-transparent pointer-events-none"></div>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- ─── Pricing Cards ─────────────────────────────────────────── -->
  <section class="bg-surface-container-low py-24">
    <div class="max-w-7xl mx-auto px-6 lg:px-8">

      <div class="text-center mb-16" data-animate="fade-up">
        <h2 class="font-headline text-3xl font-bold text-on-background mb-3">Choose Your Plan</h2>
        <p class="text-on-surface-variant font-body">All plans include a 14-day free trial on Professional tier. No credit card required.</p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-8 items-start" data-stagger>
        {plans.map(plan => (
          <div class={`relative flex flex-col h-full rounded-xl p-8 transition-all duration-300 ${
            plan.highlight
              ? 'bg-primary-container shadow-[0_20px_56px_rgba(0,44,163,0.18)] md:-translate-y-6 z-10'
              : 'bg-surface-container-lowest shadow-[0_4px_24px_rgba(26,27,36,0.04)] border border-transparent hover:border-outline-variant/25 hover:shadow-[0_12px_32px_rgba(26,27,36,0.07)] hover:-translate-y-1 mt-0 md:mt-4'
          }`}>

            {plan.badge && (
              <div class="absolute top-0 left-1/2 -translate-x-1/2 -translate-y-1/2 bg-surface-container-lowest text-primary font-bold text-xs px-4 py-1.5 rounded-full shadow-sm tracking-wider uppercase">
                {plan.badge}
              </div>
            )}

            <div class="mb-6">
              <h3 class={`font-headline text-2xl font-bold mb-2 ${plan.highlight ? 'text-on-primary' : 'text-on-background'}`}>
                {plan.name}
              </h3>
              <p class={`text-sm font-body ${plan.highlight ? 'text-on-primary/75' : 'text-on-surface-variant'}`}>
                {plan.desc}
              </p>
            </div>

            <div class="mb-8">
              <div class="flex items-baseline gap-1">
                <span class={`font-headline font-bold ${plan.highlight ? 'text-5xl text-on-primary' : 'text-4xl text-on-background'}`}>
                  {plan.price}
                </span>
                {plan.period && (
                  <span class={`text-sm font-body ${plan.highlight ? 'text-on-primary/70' : 'text-on-surface-variant'}`}>
                    {plan.period}
                  </span>
                )}
              </div>
            </div>

            <ul class="space-y-3.5 mb-10 flex-grow font-body text-sm" data-stagger>
              {plan.features.map(f => (
                <li class={`flex items-start gap-3 ${plan.highlight ? 'text-on-primary' : 'text-on-background'}`}>
                  <span class={`material-symbols-outlined text-lg leading-none shrink-0 fill mt-0.5 ${plan.highlight ? 'text-on-primary' : 'text-primary'}`}>
                    check_circle
                  </span>
                  <span set:html={f} />
                </li>
              ))}
            </ul>

            <a
              href={plan.ctaHref}
              class={`w-full py-3.5 px-6 rounded-lg font-label font-semibold text-center block transition-all duration-200 hover:-translate-y-px ${
                plan.highlight
                  ? 'bg-surface-container-lowest text-primary shadow-lg hover:bg-surface-container-low'
                  : plan.name === 'Enterprise'
                    ? 'bg-primary text-on-primary shadow-[0_4px_16px_rgba(0,44,163,0.14)] hover:bg-primary-container'
                    : 'border border-outline-variant/30 text-primary hover:bg-surface-container-low'
              }`}
            >
              {plan.cta}
            </a>

          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ─── FAQ ───────────────────────────────────────────────────── -->
  <section class="max-w-4xl mx-auto px-6 lg:px-8 py-24">
    <div class="text-center mb-14" data-animate="fade-up">
      <h2 class="font-headline text-3xl font-bold text-on-background mb-3">Enterprise Questions</h2>
      <p class="font-body text-on-surface-variant">Common inquiries about scaling with Ezeat.</p>
    </div>

    <div class="space-y-4" data-stagger>
      {faqs.map((faq, i) => (
        <div class="bg-surface-container-lowest p-6 rounded-xl border border-outline-variant/10 group hover:border-primary/20 transition-colors">
          <button
            class="w-full text-left flex items-start justify-between gap-4 cursor-pointer"
            aria-expanded="false"
            data-faq-btn
          >
            <span class="font-headline text-lg font-bold text-on-background">{faq.q}</span>
            <span class="material-symbols-outlined text-outline shrink-0 mt-0.5 transition-transform duration-200 group-[.open]:rotate-180 leading-none" data-faq-icon>
              expand_more
            </span>
          </button>
          <div class="overflow-hidden max-h-0 transition-all duration-300 ease-in-out" data-faq-answer>
            <p class="font-body text-on-surface-variant text-sm mt-4 leading-relaxed">{faq.a}</p>
          </div>
        </div>
      ))}
    </div>
  </section>

  <!-- ─── CTA ───────────────────────────────────────────────────── -->
  <section class="py-16 bg-surface-container-highest border-t border-outline-variant/10">
    <div class="max-w-3xl mx-auto px-6 text-center" data-animate="fade-up">
      <h2 class="text-3xl font-headline font-bold text-on-background mb-4">
        Still have questions?
      </h2>
      <p class="text-on-surface-variant font-body mb-8">
        Our sales team is ready to build a custom plan that fits your operational architecture.
      </p>
      <a href="/contact" class="bg-primary text-on-primary px-8 py-4 rounded-lg font-label font-medium text-lg shadow-[0_8px_24px_rgba(0,44,163,0.18)] hover:bg-primary-container hover:-translate-y-px transition-all duration-200 inline-block">
        Talk to Sales
      </a>
    </div>
  </section>

</Layout>

<script>
  // FAQ accordion
  document.querySelectorAll('[data-faq-btn]').forEach(btn => {
    btn.addEventListener('click', () => {
      const card   = btn.closest('.group') as HTMLElement;
      const answer = card?.querySelector('[data-faq-answer]') as HTMLElement;
      const icon   = btn.querySelector('[data-faq-icon]') as HTMLElement;

      const isOpen = card?.classList.contains('open');

      // Close all
      document.querySelectorAll('[data-faq-answer]').forEach((el) => {
        (el as HTMLElement).style.maxHeight = '0';
      });
      document.querySelectorAll('.group').forEach(c => c.classList.remove('open'));

      if (!isOpen && answer) {
        answer.style.maxHeight = answer.scrollHeight + 'px';
        card?.classList.add('open');
      }
    });
  });
</script>

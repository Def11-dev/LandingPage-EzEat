---
import Layout from '../layouts/Layout.astro';

const row1 = [
  {
    id: 'foodtruck',
    name: 'Food Truck / Pop-ups',
    tagline: 'Operación ligera para negocios en movimiento.',
    description: 'PDV móvil con modo offline (PWA) que sincroniza al recuperar señal. Ideal para festivales y eventos.',
    price: '$699',
    unit: 'MXN /mes',
    includes: ['PDV Básico', 'Pedidos en Línea', 'KDS — Pantallas de Cocina'],
    addons: ['Sistema de Lealtad', 'Kioskos de Autoservicio', 'Control de Inventarios', 'Integración de Delivery', 'Analítica Avanzada'],
    note: 'Compatible con tarjetas SIM M2M/IoT desde $30–60 MXN al mes para tener internet siempre.',
    cta: 'Empezar',
    ctaHref: '/contact',
    popular: false,
  },
  {
    id: 'emprendedor',
    name: 'Emprendedor',
    tagline: 'Tu primero de muchos restaurantes.',
    description: 'Te ayudamos a operar como las grandes cadenas desde el día uno. Disponible en versión QSR (comida rápida) y Tradicional (mesas).',
    price: '$899',
    unit: 'MXN /mes',
    includes: ['PDV Básico', 'Pedidos en Línea', 'Sistema de Lealtad', 'KDS — Pantallas de Cocina'],
    addons: ['Analítica Avanzada', 'Integración de Delivery', 'Sistema de Reservaciones'],
    note: 'Otros sistemas te obligan a gastar miles en impresoras y papel. EzEat te regala el KDS al contratar plan anual.',
    cta: 'Empezar',
    ctaHref: '/contact',
    popular: false,
  },
  {
    id: 'darkkitchen',
    name: 'Dark Kitchen',
    tagline: 'No más tablets sonando.',
    description: 'Una sola pantalla para cocinar todo. Pensado para cocinas 100% delivery.',
    price: '$1,499',
    unit: 'MXN /mes',
    includes: ['KDS — Pantallas de Cocina', 'Integración de Delivery', 'Control de Inventarios', 'Pedidos en Línea', 'PDV Básico'],
    addons: ['Sistema de Lealtad', 'Analítica Avanzada', 'Pedidos por WhatsApp con IA'],
    note: null,
    cta: 'Empezar',
    ctaHref: '/contact',
    popular: false,
  },
];

const row2 = [
  {
    id: 'escalamiento',
    name: 'Escalamiento',
    tagline: 'De emprendedor a empresario.',
    description: 'Control total sin estar ahí. Si creces, crecemos juntos.',
    price: '$1,699',
    unit: 'MXN /mes',
    subprice: null,
    includes: ['PDV Inteligente', 'Analítica Avanzada', 'Gestión de Personal', 'Integración de Delivery', 'Control de Inventarios', 'Pedidos en Línea', 'KDS — Pantallas de Cocina', 'Sistema de Lealtad'],
    addons: ['Kioskos de Autoservicio', 'Comanda Digital de Meseros'],
    note: null,
    cta: 'Empezar',
    ctaHref: '/contact',
    popular: true,
  },
  {
    id: 'hoteles',
    name: 'Hoteles y Moteles',
    tagline: 'Transforma el teléfono del huésped en tu mejor mesero.',
    description: 'Pedidos desde la habitación vía QR o NFC, con cargo directo a la cuenta del hotel.',
    price: '$2,899',
    unit: 'MXN /mes',
    includes: ['Room Service Hotelero', 'PDV Básico', 'KDS — Pantallas de Cocina', 'Facturación Electrónica', 'Control de Inventarios'],
    addons: ['Analítica Avanzada', 'Integración de Delivery'],
    note: null,
    cta: 'Empezar',
    ctaHref: '/contact',
    popular: false,
  },
  {
    id: 'corporativo',
    name: 'Corporativo',
    tagline: 'Auditoría total en tiempo real.',
    description: 'Si falta un peso, EzEat te dice dónde. Acceso a todas las features del ecosistema.',
    price: null,
    unit: null,
    includes: ['PDV Inteligente', 'KDS — Pantallas de Cocina', 'Kioskos de Autoservicio', 'Pedidos en Línea', 'Sistema de Lealtad', 'Comanda Digital de Meseros', 'Control de Inventarios', 'Compras y Proveedores', 'Analítica Avanzada', 'Gestión de Personal', 'Integración de Delivery', 'Facturación Electrónica', 'Estados Financieros con IA', 'Sistema de Reservaciones', 'Gestión de Colas', 'Pedidos por WhatsApp con IA', 'Pedidos por Llamada con IA'],
    addons: [],
    note: null,
    cta: 'Solicitar cotización',
    ctaHref: '/contact',
    popular: false,
  },
];
---

<Layout
  title="Precios — EzEat"
  description="Elige el plan EzEat que mejor se adapta a tu operación. Desde Food Trucks hasta corporativos multi-marca."
>

  <!-- Hero -->
  <section class="pt-16 pb-16 flex items-center justify-center" style="background: linear-gradient(135deg, #0f1729 0%, #141d3d 50%, #1a2450 100%);">
    <div class="max-w-3xl mx-auto px-6 text-center" data-animate="fade-up">
      <div class="inline-flex items-center gap-2 bg-white/10 border border-white/20 px-4 py-2 rounded-full mb-6">
        <span class="material-symbols-outlined text-[#b0beff] text-base leading-none">auto_awesome</span>
        <span class="text-sm font-label font-medium text-white/90">Precios transparentes</span>
      </div>
      <h1 class="font-headline text-5xl md:text-6xl font-bold tracking-tight text-white leading-[1.05] mb-5">
        Elige un plan o <span class="text-[#b0beff]">arma el tuyo</span>
      </h1>
      <p class="font-body text-lg text-white/70 max-w-xl mx-auto mb-8">
        Planes pensados para cada tipo de negocio. Si prefieres, configura módulos uno por uno.
      </p>
      <!-- Tab switcher -->
      <div class="inline-flex items-center bg-white/10 border border-white/15 rounded-full p-1 gap-1">
        <span class="px-5 py-2 rounded-full bg-white font-label font-medium text-sm text-on-surface cursor-default">
          Planes preconfigurados
        </span>
        <a href="/pricing/alacarta"
          class="px-5 py-2 rounded-full font-label font-medium text-sm text-white/60 hover:text-white transition-colors">
          A la carta
        </a>
      </div>
    </div>
  </section>

  <!-- Plans -->
  <section class="pb-24 bg-surface">
    <div class="max-w-7xl mx-auto px-6 lg:px-8 space-y-8">

      <!-- Row 1 -->
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6" data-stagger>
        {row1.map(plan => (
          <div class="relative bg-white rounded-2xl border border-outline-variant/20 shadow-sm flex flex-col overflow-hidden">
            <div class="p-7 flex-1 flex flex-col">
              <!-- Header -->
              <h2 class="font-headline text-2xl font-bold text-on-background">{plan.name}</h2>
              <p class="text-primary font-body text-sm font-medium mt-1">{plan.tagline}</p>
              <p class="text-on-surface-variant font-body text-sm mt-3 leading-relaxed">{plan.description}</p>

              <!-- Price -->
              <div class="mt-6 mb-5">
                <span class="font-headline font-extrabold text-5xl text-on-background">{plan.price}</span>
                <span class="text-on-surface-variant font-body text-sm ml-1">{plan.unit}</span>
              </div>

              <!-- Includes -->
              <p class="text-[10px] font-label font-semibold tracking-widest text-on-surface-variant uppercase mb-3">Incluye</p>
              <ul class="space-y-2 mb-6">
                {plan.includes.map(item => (
                  <li class="flex items-center gap-2 text-sm font-body text-on-surface">
                    <span class="material-symbols-outlined text-primary text-base leading-none fill">check_circle</span>
                    {item}
                  </li>
                ))}
              </ul>

              <!-- Add-ons -->
              {plan.addons.length > 0 && (
                <>
                  <p class="text-[10px] font-label font-semibold tracking-widest text-on-surface-variant uppercase mb-3">Add-ons disponibles</p>
                  <ul class="space-y-2 mb-6">
                    {plan.addons.map(item => (
                      <li class="flex items-center gap-2 text-sm font-body text-on-surface-variant">
                        <span class="material-symbols-outlined text-outline text-base leading-none">add</span>
                        {item}
                      </li>
                    ))}
                  </ul>
                </>
              )}

              <!-- Note -->
              {plan.note && (
                <div class="mt-auto mb-5 bg-surface-container-low rounded-lg px-4 py-3 text-xs font-body text-on-surface-variant leading-relaxed">
                  {plan.note}
                </div>
              )}

              <div class="mt-auto"></div>
            </div>

            <!-- CTA -->
            <div class="px-7 pb-7">
              <a
                href={plan.ctaHref}
                class="w-full border border-outline-variant/30 text-on-surface font-label font-medium py-3 rounded-lg flex items-center justify-center gap-2 hover:border-primary/40 hover:text-primary transition-all duration-200 text-sm"
              >
                {plan.cta}
                <span class="material-symbols-outlined text-base leading-none">arrow_forward</span>
              </a>
            </div>
          </div>
        ))}
      </div>

      <!-- Row 2 -->
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6" data-stagger>
        {row2.map(plan => (
          <div class={`relative bg-white rounded-2xl border flex flex-col overflow-hidden shadow-sm ${plan.popular ? 'border-primary shadow-[0_0_0_2px_#2b49f3]' : 'border-outline-variant/20'}`}>

            {plan.popular && (
              <div class="flex justify-center -mt-px">
                <div class="inline-flex items-center gap-1.5 bg-primary text-on-primary text-xs font-label font-semibold px-4 py-1.5 rounded-b-xl">
                  <span class="material-symbols-outlined text-sm leading-none fill">star</span>
                  Más popular
                </div>
              </div>
            )}

            <div class="p-7 flex-1 flex flex-col">
              <!-- Header -->
              <h2 class="font-headline text-2xl font-bold text-on-background">{plan.name}</h2>
              <p class="text-primary font-body text-sm font-medium mt-1">{plan.tagline}</p>
              <p class="text-on-surface-variant font-body text-sm mt-3 leading-relaxed">{plan.description}</p>

              <!-- Price -->
              <div class="mt-6 mb-1">
                {plan.price ? (
                  <>
                    <span class="font-headline font-extrabold text-5xl text-on-background">{plan.price}</span>
                    <span class="text-on-surface-variant font-body text-sm ml-1">{plan.unit}</span>
                  </>
                ) : (
                  <span class="font-headline font-extrabold text-4xl text-primary">Cotización a medida</span>
                )}
              </div>
              {'subprice' in plan && plan.subprice && (
                <p class="text-on-surface-variant font-body text-xs mb-4">{plan.subprice}</p>
              )}

              <!-- Includes -->
              <p class="text-[10px] font-label font-semibold tracking-widest text-on-surface-variant uppercase mb-3 mt-4">Incluye</p>
              <ul class="space-y-2 mb-6">
                {plan.includes.map(item => (
                  <li class="flex items-center gap-2 text-sm font-body text-on-surface">
                    <span class="material-symbols-outlined text-primary text-base leading-none fill">check_circle</span>
                    {item}
                  </li>
                ))}
              </ul>

              <!-- Add-ons -->
              {plan.addons.length > 0 && (
                <>
                  <p class="text-[10px] font-label font-semibold tracking-widest text-on-surface-variant uppercase mb-3">Add-ons disponibles</p>
                  <ul class="space-y-2 mb-6">
                    {plan.addons.map(item => (
                      <li class="flex items-center gap-2 text-sm font-body text-on-surface-variant">
                        <span class="material-symbols-outlined text-outline text-base leading-none">add</span>
                        {item}
                      </li>
                    ))}
                  </ul>
                </>
              )}

              <div class="mt-auto"></div>
            </div>

            <!-- CTA -->
            <div class="px-7 pb-7">
              <a
                href={plan.ctaHref}
                class={`w-full font-label font-medium py-3 rounded-lg flex items-center justify-center gap-2 transition-all duration-200 text-sm ${plan.popular ? 'bg-primary text-on-primary hover:brightness-110' : 'border border-outline-variant/30 text-on-surface hover:border-primary/40 hover:text-primary'}`}
              >
                {plan.cta}
                <span class="material-symbols-outlined text-base leading-none">arrow_forward</span>
              </a>
            </div>
          </div>
        ))}
      </div>

    </div>
  </section>

  <!-- A la carta -->
  <section class="py-12 bg-surface border-t border-outline-variant/10">
    <div class="max-w-xl mx-auto px-6 text-center" data-animate="fade-up">
      <p class="text-on-surface-variant font-body text-base mb-5">¿Necesitas algo distinto? Configura módulo por módulo.</p>
      <a href="/pricing/alacarta"
        class="inline-flex items-center gap-2 border border-outline-variant/30 text-on-surface font-label font-medium px-7 py-3 rounded-lg hover:border-primary/40 hover:text-primary transition-all duration-200">
        Ir al modo A la carta
        <span class="material-symbols-outlined text-base leading-none">arrow_forward</span>
      </a>
    </div>
  </section>

</Layout>

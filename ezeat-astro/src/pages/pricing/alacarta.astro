---
import Layout from '../../layouts/Layout.astro';

const modules = [
  { id: 'pos_basic',    label: 'POS Básico',               price: 599,  icon: 'point_of_sale',  category: 'operativa' },
  { id: 'pos_smart',    label: 'POS Inteligente',           price: 1200, icon: 'tablet_android',  category: 'operativa' },
  { id: 'kds',          label: 'KDS - Pantallas de Cocina', price: 450,  icon: 'kitchen',         category: 'operativa' },
  { id: 'kioscos',      label: 'Kioskos de Autoservicio',   price: 1000, icon: 'smart_display',   category: 'addons' },
  { id: 'inventory',    label: 'Inventarios con IA',        price: 750,  icon: 'inventory_2',     category: 'addons' },
  { id: 'delivery',     label: 'Delivery Integrado',        price: 400,  icon: 'delivery_dining', category: 'addons' },
  { id: 'finance_ai',   label: 'IA Financiera',             price: 1250, icon: 'account_balance', category: 'addons' },
  { id: 'roomservice',  label: 'Room Service (Hoteles)',    price: 1500, icon: 'room_service',    category: 'addons' },
];
---

<Layout
  title="A la carta — EzEat"
  description="Arma tu EzEat ideal módulo por módulo. Sin paquetes forzosos, activa solo lo que necesitas."
>

  <!-- Hero -->
  <section class="pt-16 pb-12 bg-surface">
    <div class="max-w-7xl mx-auto px-6 lg:px-8 text-center" data-animate="fade-up">
      <a href="/pricing" class="inline-flex items-center gap-1.5 text-sm font-body text-on-surface-variant hover:text-primary transition-colors mb-6">
        <span class="material-symbols-outlined text-base leading-none">arrow_back</span>
        Ver planes fijos
      </a>
      <div class="inline-flex items-center gap-2 bg-surface-container-highest px-4 py-2 rounded-full mb-6">
        <span class="material-symbols-outlined text-primary text-base leading-none">construction</span>
        <span class="text-sm font-label font-medium text-on-surface">Build Your Own OS</span>
      </div>
      <h1 class="font-headline text-5xl md:text-6xl font-bold tracking-tight text-on-background leading-[1.05] mb-5">
        Arma tu <span class="text-primary">EzEat ideal.</span>
      </h1>
      <p class="font-body text-xl text-on-surface-variant max-w-2xl mx-auto">
        Sin paquetes. Sin sorpresas. Activa solo los módulos que necesitas y ve tu inversión en tiempo real.
      </p>
      <div id="diag-banner" class="hidden mt-8 inline-flex items-center gap-3 bg-primary/8 border border-primary/20 px-5 py-3 rounded-xl">
        <span class="material-symbols-outlined text-primary text-xl leading-none">auto_awesome</span>
        <span class="text-sm font-body text-on-surface">Basado en tu diagnóstico, hemos pre-seleccionado estas herramientas para ti.</span>
      </div>
    </div>
  </section>

  <!-- Simulator -->
  <section class="pb-24 bg-surface">
    <div class="max-w-7xl mx-auto px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-5 gap-10 items-start">

        <!-- Left: Control panel -->
        <div class="lg:col-span-3 space-y-8">

          <div class="bg-surface-container-lowest rounded-xl p-7 border border-outline-variant/10" data-animate="slide-right">
            <h2 class="font-headline text-lg font-bold text-on-background mb-1">Paso 1: ¿Cuántas sucursales?</h2>
            <p class="text-on-surface-variant text-sm font-body mb-5">Multiplica el costo base por ubicación.</p>
            <div class="flex items-center gap-4">
              <button id="branches-dec" class="w-10 h-10 rounded-full border border-outline-variant/25 flex items-center justify-center text-on-surface hover:bg-surface-container-low transition-colors font-bold text-lg">−</button>
              <div class="flex-1 text-center">
                <span id="branches-val" class="font-headline font-extrabold text-4xl text-primary">1</span>
                <span class="text-on-surface-variant font-body text-sm ml-2">sucursal(es)</span>
              </div>
              <button id="branches-inc" class="w-10 h-10 rounded-full border border-outline-variant/25 flex items-center justify-center text-on-surface hover:bg-surface-container-low transition-colors font-bold text-lg">+</button>
            </div>
            <p id="fleet-msg" class="hidden mt-4 text-xs font-body text-primary bg-primary/8 px-4 py-2.5 rounded-lg">
              ¿Tienes más de 5 sucursales? <a href="/contact" class="font-semibold underline">Hablemos de un precio especial para flotas.</a>
            </p>
          </div>

          <div class="bg-surface-container-lowest rounded-xl p-7 border border-outline-variant/10" data-animate="slide-right">
            <h2 class="font-headline text-lg font-bold text-on-background mb-1">Paso 2: Elige tu operativa</h2>
            <p class="text-on-surface-variant text-sm font-body mb-5">Los módulos esenciales para tu operación diaria.</p>
            <div class="space-y-3" id="modules-operativa"></div>
          </div>

          <div class="bg-surface-container-lowest rounded-xl p-7 border border-outline-variant/10" data-animate="slide-right">
            <h2 class="font-headline text-lg font-bold text-on-background mb-1">Paso 3: Añade superpoderes</h2>
            <p class="text-on-surface-variant text-sm font-body mb-5">Módulos para escalar y diferenciarte.</p>
            <div class="space-y-3" id="modules-addons"></div>
          </div>

        </div>

        <!-- Right: Floating summary -->
        <div class="lg:col-span-2 lg:sticky lg:top-24" data-animate="slide-left">
          <div class="bg-surface-container-lowest rounded-xl border border-outline-variant/15 shadow-[0_16px_48px_rgba(26,27,36,0.07)] overflow-hidden">
            <div class="bg-primary px-7 py-5">
              <h3 class="font-headline font-bold text-on-primary text-lg">Tu Configuración EzEat</h3>
              <p class="text-on-primary/70 text-sm font-body mt-0.5">Resumen en tiempo real</p>
            </div>
            <div class="p-7">
              <div id="summary-list" class="space-y-2 mb-6 min-h-[80px]">
                <p class="text-on-surface-variant text-sm font-body italic">Selecciona módulos para comenzar...</p>
              </div>
              <div class="border-t border-outline-variant/15 pt-5 mb-6">
                <div class="flex justify-between items-center mb-1">
                  <span class="text-sm font-label text-on-surface-variant">Módulos seleccionados × <span id="summary-branches">1</span> sucursal(es)</span>
                </div>
                <div class="flex justify-between items-end mt-3">
                  <span class="text-sm font-label font-medium text-on-surface-variant">Inversión mensual estimada</span>
                </div>
                <div class="mt-2">
                  <span id="total-price" class="font-headline font-extrabold text-4xl text-primary transition-all duration-300">$0</span>
                  <span class="text-on-surface-variant font-body text-sm ml-1">/mes MXN</span>
                </div>
              </div>
              <a href="/contact" id="cta-demo"
                class="w-full bg-primary text-on-primary py-4 rounded-lg font-label font-semibold text-base shadow-[0_8px_24px_rgba(0,44,163,0.18)] hover:brightness-110 hover:-translate-y-px transition-all duration-200 flex items-center justify-center gap-2">
                Solicitar Demo con este Plan
                <span class="material-symbols-outlined text-xl leading-none">calendar_month</span>
              </a>
              <p class="text-center text-xs text-on-surface-variant font-body mt-4">Sin tarjeta de crédito · Demo gratuita</p>
            </div>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- Mobile sticky -->
  <div id="mobile-sticky" class="lg:hidden fixed bottom-0 left-0 right-0 bg-surface-container-lowest border-t border-outline-variant/15 shadow-[0_-8px_24px_rgba(26,27,36,0.1)] px-5 py-4 flex items-center justify-between z-50">
    <div>
      <p class="text-xs font-label text-on-surface-variant">Inversión estimada</p>
      <p id="mobile-price" class="font-headline font-bold text-xl text-primary">$0<span class="text-sm font-body text-on-surface-variant">/mes</span></p>
    </div>
    <a href="/contact" class="bg-primary text-on-primary px-6 py-3 rounded-lg font-label font-semibold text-sm shadow-[0_4px_16px_rgba(0,44,163,0.2)] hover:-translate-y-px transition-all">
      Solicitar Demo
    </a>
  </div>

</Layout>

<script define:vars={{ modules }}>
  let branches = 1;
  const selected = new Set();

  const REC_MAP = {
    kioscos: 'kioscos', analytics: 'kioscos', roomservice: 'roomservice',
    inventory: 'inventory', delivery: 'delivery', pos: 'pos_smart',
  };
  let diagRecs = [];
  try {
    const stored = localStorage.getItem('ezeat_recs');
    const storedBranches = localStorage.getItem('ezeat_branches');
    if (stored) diagRecs = JSON.parse(stored);
    if (storedBranches) {
      const b = parseInt(storedBranches);
      if (!isNaN(b)) branches = Math.max(1, b === '1' ? 1 : b === '2-5' ? 3 : b === '6-20' ? 10 : 20);
    }
  } catch {}

  function renderModules() {
    ['operativa', 'addons'].forEach(cat => {
      const container = document.getElementById(`modules-${cat}`);
      if (!container) return;
      const mods = modules.filter(m => m.category === cat);
      container.innerHTML = mods.map(m => {
        const isSelected = selected.has(m.id);
        return `
          <button data-module="${m.id}" data-price="${m.price}"
            class="module-btn w-full flex items-center gap-4 p-4 rounded-xl border ${isSelected ? 'border-primary bg-primary/5 shadow-[0_4px_12px_rgba(0,44,163,0.1)]' : 'border-outline-variant/15 bg-surface-container-low hover:border-primary/30'} transition-all duration-200 text-left group">
            <div class="w-10 h-10 ${isSelected ? 'bg-primary/15' : 'bg-primary/8'} rounded-lg flex items-center justify-center text-primary shrink-0 transition-colors">
              <span class="material-symbols-outlined text-lg leading-none">${m.icon}</span>
            </div>
            <div class="flex-1">
              <span class="font-body font-semibold text-on-surface text-sm block">${m.label}</span>
              <span class="text-xs text-on-surface-variant font-body">$${m.price.toLocaleString()} MXN/sucursal</span>
            </div>
            <div class="w-6 h-6 rounded-full border-2 ${isSelected ? 'border-primary bg-primary flex items-center justify-center' : 'border-outline-variant/40'} shrink-0 transition-all">
              ${isSelected ? '<span class="material-symbols-outlined text-on-primary text-sm leading-none">check</span>' : ''}
            </div>
          </button>`;
      }).join('');
      container.querySelectorAll('.module-btn').forEach(btn => {
        btn.addEventListener('click', () => {
          const id = btn.dataset.module;
          if (selected.has(id)) selected.delete(id); else selected.add(id);
          renderModules(); updateSummary();
        });
      });
    });
  }

  function updateSummary() {
    const summaryList = document.getElementById('summary-list');
    const totalEl = document.getElementById('total-price');
    const mobileEl = document.getElementById('mobile-price');
    const branchesEl = document.getElementById('summary-branches');
    if (branchesEl) branchesEl.textContent = String(branches);
    const selectedMods = modules.filter(m => selected.has(m.id));
    const total = selectedMods.reduce((s, m) => s + m.price, 0) * branches;
    if (summaryList) {
      summaryList.innerHTML = selectedMods.length === 0
        ? '<p class="text-on-surface-variant text-sm font-body italic">Selecciona módulos para comenzar...</p>'
        : selectedMods.map(m => `<div class="flex justify-between items-center text-sm font-body"><span class="text-on-surface">${m.label}</span><span class="text-on-surface-variant">$${(m.price * branches).toLocaleString()}</span></div>`).join('');
    }
    const formatted = `$${total.toLocaleString()}`;
    if (totalEl) totalEl.textContent = formatted;
    if (mobileEl) mobileEl.innerHTML = `${formatted}<span class="text-sm font-body text-on-surface-variant">/mes</span>`;
  }

  document.getElementById('branches-dec')?.addEventListener('click', () => {
    if (branches > 1) { branches--; updateBranchUI(); }
  });
  document.getElementById('branches-inc')?.addEventListener('click', () => { branches++; updateBranchUI(); });

  function updateBranchUI() {
    const branchesVal = document.getElementById('branches-val');
    const fleetMsg = document.getElementById('fleet-msg');
    if (branchesVal) branchesVal.textContent = String(branches);
    if (fleetMsg) fleetMsg.classList.toggle('hidden', branches <= 5);
    updateSummary();
  }

  if (diagRecs.length > 0) {
    document.getElementById('diag-banner')?.classList.remove('hidden');
    diagRecs.forEach(rec => { const mapped = REC_MAP[rec]; if (mapped) selected.add(mapped); });
  }
  const branchesVal = document.getElementById('branches-val');
  if (branchesVal) branchesVal.textContent = String(branches);
  renderModules(); updateSummary();
</script>

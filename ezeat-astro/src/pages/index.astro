const terminalImg = 'https://lh3.googleusercontent.com/aida-public/AB6AXuC7kVKpA67m77WIr_OP6QaM9OEuuAgLLF7gCo9P4QY42_Pb-Z6NU82oT-ro-O1X6wTEZr-dWnel0wnrI0oGHDXm08NDTpVAADalzFz--IW6dMDweqJhZznZsYo-avqfhghdOwP79fM9xw_LZr_BbIw0LF9-5-2NOHvYvJygIOoDTcaBQIxt2OwaAuZAvDjnw9cWfAgccA0TrzqokRGPu3EPkDRrcdLHL8N8Rnk0jo_zLWQqpIz9Rp837kO22M1Ym1qnXqNgmiuw1uIA';

const questions = [
  {
    id: 'locations',
    text: '¿Cuántas ubicaciones tiene tu restaurante?',
    options: [
      { value: '1',   label: '1 sola ubicación',    icon: 'store' },
      { value: '2-5', label: '2 a 5 ubicaciones',   icon: 'storefront' },
      { value: '6-20',label: '6 a 20 ubicaciones',  icon: 'location_city' },
      { value: '20+', label: 'Más de 20 ubicaciones',icon: 'corporate_fare' },
    ],
  },
  {
    id: 'challenge',
    text: '¿Cuál es tu mayor reto operativo hoy?',
    options: [
      { value: 'wait',   label: 'Tiempos de espera altos',        icon: 'hourglass_empty' },
      { value: 'errors', label: 'Errores frecuentes en pedidos',   icon: 'error_outline' },
      { value: 'labor',  label: 'Costos laborales elevados',       icon: 'payments' },
      { value: 'data',   label: 'Falta de datos e informes',       icon: 'bar_chart' },
    ],
  },
  {
    id: 'orders',
    text: '¿Cómo gestionas los pedidos actualmente?',
    options: [
      { value: 'cashier', label: 'Caja con empleado',         icon: 'point_of_sale' },
      { value: 'waiter',  label: 'Mesero en mesa',            icon: 'restaurant' },
      { value: 'app',     label: 'App propia o delivery',     icon: 'smartphone' },
      { value: 'none',    label: 'Sin sistema definido',      icon: 'help_outline' },
    ],
  },
  {
    id: 'employees',
    text: '¿Cuántos empleados de atención al cliente por turno?',
    options: [
      { value: '1-3',  label: '1 a 3 empleados',    icon: 'person' },
      { value: '4-8',  label: '4 a 8 empleados',    icon: 'group' },
      { value: '9-20', label: '9 a 20 empleados',   icon: 'groups' },
      { value: '20+',  label: 'Más de 20 empleados',icon: 'supervisor_account' },
    ],
  },
  {
    id: 'tracking',
    text: '¿Cómo llevas el control de ventas y datos?',
    options: [
      { value: 'yes',    label: 'Sistema digital completo', icon: 'dashboard' },
      { value: 'partial',label: 'Solo parcialmente',        icon: 'analytics' },
      { value: 'manual', label: 'Manual (hojas / Excel)',   icon: 'table_chart' },
      { value: 'no',     label: 'No llevamos control',      icon: 'block' },

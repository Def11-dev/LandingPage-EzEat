---

<Layout
  title="EzEat · Diagnóstico de eficiencia para tu restaurante"
  description="Descubre qué tecnología necesita tu restaurante para escalar. Diagnóstico gratuito en 60 segundos con EzEat."
>

<!-- ═══════════════════════════════════════════════
     STAGE 1 · HERO
═══════════════════════════════════════════════ -->
<section id="stage-hero" class="relative min-h-[90vh] bg-surface flex items-center pt-8 pb-24 overflow-hidden">
  <div class="absolute inset-0 bg-gradient-to-br from-surface via-surface to-surface-container-low opacity-60 pointer-events-none"></div>
  <div class="absolute -top-32 -right-32 w-[600px] h-[600px] rounded-full bg-primary/5 pointer-events-none"></div>
  <div class="absolute -bottom-24 -left-24 w-[400px] h-[400px] rounded-full bg-primary/3 pointer-events-none"></div>

  <div class="max-w-7xl mx-auto px-6 lg:px-8 w-full relative z-10">
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-8 items-center">

      <!-- Text -->
      <div class="lg:col-span-7 space-y-8">
        <div data-animate="fade-up" class="inline-flex items-center gap-2 bg-surface-container-highest px-4 py-2 rounded-full">
          <span class="material-symbols-outlined text-primary text-base leading-none">bolt</span>
          <span class="text-sm font-label font-medium text-on-surface">Diagnóstico gratuito · 60 segundos</span>
        </div>

        <h1 data-animate="fade-up" style="transition-delay:0.1s"
          class="text-5xl md:text-6xl lg:text-[4rem] leading-[1.08] font-headline font-extrabold text-on-background tracking-tight">
          Descubre qué tecnología necesita tu restaurante para
          <span class="text-primary relative">
            escalar
            <span class="absolute -bottom-1 left-0 right-0 h-[3px] bg-primary/25 rounded-full"></span>
          </span>
        </h1>

        <p data-animate="fade-up" style="transition-delay:0.2s"
          class="text-xl md:text-2xl text-on-surface-variant font-body max-w-2xl leading-relaxed">
          Responde 5 preguntas rápidas y obtén un diagnóstico personalizado de las soluciones Ezeat más adecuadas para tu operación.
        </p>

        <div data-animate="fade-up" style="transition-delay:0.3s" class="flex flex-col sm:flex-row gap-4 pt-2">
          <button
            id="btn-start"
            class="bg-primary text-on-primary px-8 py-4 rounded-lg font-label font-semibold text-lg shadow-[0_8px_32px_rgba(0,44,163,0.25)] hover:bg-primary-container hover:-translate-y-px transition-all duration-200 flex items-center justify-center gap-2"
          >
            Comenzar diagnóstico
            <span class="material-symbols-outlined text-xl leading-none">arrow_forward</span>
          </button>
          <a href="/services"
            class="border border-outline-variant/30 bg-surface-container-lowest text-on-surface px-8 py-4 rounded-lg font-label font-medium text-lg hover:border-primary/40 hover:bg-surface-container-low transition-all duration-200 flex items-center justify-center">
            Ver soluciones
          </a>
        </div>
      </div>

      <!-- Image -->
      <div class="lg:col-span-5 relative" data-animate="slide-left" style="transition-delay:0.2s">
        <div class="relative w-full aspect-[4/5] rounded-xl overflow-hidden shadow-[0_32px_64px_rgba(26,27,36,0.1)]">
          <img src={heroImg} alt="Kiosco de autoservicio Ezeat en restaurante moderno" class="w-full h-full object-cover" loading="eager" />
          <div class="absolute inset-0 bg-gradient-to-t from-on-background/10 to-transparent pointer-events-none"></div>
        </div>

        <!-- Floating badge -->
        <div class="animate-float absolute -bottom-6 -left-10 w-56 p-5 bg-surface-container-lowest rounded-xl shadow-[0_16px_40px_rgba(26,27,36,0.1)] border border-outline-variant/15 hidden lg:block">
          <div class="flex items-center gap-3 mb-2">
            <span class="material-symbols-outlined text-primary text-2xl fill leading-none">speed</span>
            <span class="font-headline font-bold text-on-surface text-lg">40%</span>
          </div>
          <p class="text-xs font-body text-on-surface-variant leading-snug">Reducción promedio en costos laborales con Ezeat</p>
        </div>

        <div class="absolute -top-4 -right-4 px-4 py-2 bg-primary rounded-xl shadow-lg hidden lg:flex items-center gap-2">
          <span class="material-symbols-outlined text-on-primary text-sm leading-none fill">verified</span>
          <span class="text-on-primary text-xs font-label font-semibold">500+ restaurantes</span>
        </div>
      </div>

    </div>
  </div>
</section>

<!-- Stats bar -->
<section id="stage-hero-stats" class="bg-primary py-10">
  <div class="max-w-7xl mx-auto px-6 lg:px-8">
    <div class="grid grid-cols-2 md:grid-cols-4 gap-8 text-center" data-stagger>
      {[
        { value: '500+',  label: 'Restaurantes activos' },
        { value: '<1s',   label: 'Velocidad de transacción' },
        { value: '40%',   label: 'Reducción costos laborales' },
        { value: '24/7',  label: 'Soporte empresarial' },
      ].map(s => (
        <div>
          <div class="text-3xl font-headline font-extrabold text-on-primary">{s.value}</div>
          <div class="text-sm font-body text-on-primary/70 mt-1">{s.label}</div>
        </div>
      ))}
    </div>
  </div>
</section>


<!-- ═══════════════════════════════════════════════
     STAGE 2 · QUIZ
═══════════════════════════════════════════════ -->
<section id="stage-quiz" class="hidden min-h-screen bg-surface py-16">
  <div class="max-w-2xl mx-auto px-6">

    <!-- Progress -->
    <div class="mb-10">
      <div class="flex justify-between items-center mb-3">
        <span class="text-sm font-label font-medium text-on-surface-variant" id="question-counter">Pregunta 1 de 5</span>
        <button id="btn-quiz-close" class="text-on-surface-variant hover:text-on-surface transition-colors p-1 rounded">
          <span class="material-symbols-outlined text-xl leading-none">close</span>
        </button>
      </div>
      <div class="w-full h-1.5 bg-surface-container-highest rounded-full overflow-hidden">
        <div id="progress-bar" class="h-full bg-primary rounded-full transition-all duration-500 ease-out" style="width:20%"></div>
      </div>
    </div>

    <!-- Questions (one rendered per question, shown/hidden by JS) -->
    {questions.map((q, qi) => (
      <div data-question={qi} class={qi === 0 ? 'quiz-question' : 'quiz-question hidden'}>
        <h2 class="font-headline text-3xl md:text-4xl font-extrabold text-on-background mb-2 leading-tight">
          {q.text}
        </h2>
        <p class="text-on-surface-variant font-body mb-8 text-base">Selecciona la opción que mejor describe tu situación.</p>

        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
          {q.options.map(opt => (
            <button
              data-q={q.id}
              data-v={opt.value}
              class="quiz-option group flex items-center gap-4 p-5 bg-surface-container-lowest rounded-xl border border-outline-variant/15 hover:border-primary/40 hover:bg-surface-container-low hover:shadow-[0_8px_24px_rgba(0,44,163,0.08)] transition-all duration-200 text-left w-full"
            >
              <div class="w-11 h-11 bg-primary/8 rounded-lg flex items-center justify-center text-primary shrink-0 group-hover:bg-primary/15 transition-colors">
                <span class="material-symbols-outlined text-xl leading-none">{opt.icon}</span>
              </div>
              <span class="font-body font-medium text-on-surface text-sm leading-snug">{opt.label}</span>
            </button>
          ))}
        </div>
      </div>
    ))}

    <!-- Back button -->
    <div class="mt-10 flex items-center gap-4">
      <button id="btn-back" class="hidden flex items-center gap-2 text-on-surface-variant font-label font-medium hover:text-on-surface transition-colors py-2">
        <span class="material-symbols-outlined text-xl leading-none">arrow_back</span>
        Anterior
      </button>
    </div>

  </div>
</section>


<!-- ═══════════════════════════════════════════════
     STAGE 3 · RESULTS
═══════════════════════════════════════════════ -->
<section id="stage-results" class="hidden min-h-screen bg-surface py-20">
  <div class="max-w-4xl mx-auto px-6">

    <!-- Header -->
    <div class="text-center mb-16" data-animate="fade-up">
      <div class="inline-flex items-center gap-2 bg-surface-container-highest px-4 py-2 rounded-full mb-6">
        <span class="material-symbols-outlined text-primary text-base leading-none fill">check_circle</span>
        <span class="text-sm font-label font-medium text-on-surface">Diagnóstico completado</span>
      </div>
      <h2 class="font-headline text-4xl md:text-5xl font-extrabold text-on-background mb-4 leading-tight">
        Tu diagnóstico está <span class="text-primary">listo</span>
      </h2>
      <p class="text-on-surface-variant font-body text-lg max-w-xl mx-auto">
        Basado en tus respuestas, estas son las soluciones Ezeat más adecuadas para tu restaurante.
      </p>
    </div>

    <!-- Result cards — rendered by JS -->
    <div id="result-cards" class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-14"></div>

    <!-- CTAs -->
    <div class="flex flex-col sm:flex-row justify-center gap-4">
      <a href="/contact"
        class="bg-primary text-on-primary px-8 py-4 rounded-lg font-label font-semibold text-base shadow-[0_8px_32px_rgba(0,44,163,0.2)] hover:bg-primary-container hover:-translate-y-px transition-all duration-200 flex items-center justify-center gap-2">
        Agendar demo gratuita
        <span class="material-symbols-outlined text-xl leading-none">calendar_month</span>
      </a>
      <button id="btn-restart"
        class="border border-outline-variant/30 text-on-surface px-8 py-4 rounded-lg font-label font-medium text-base hover:bg-surface-container-low hover:border-primary/30 transition-all duration-200">
        Repetir diagnóstico
      </button>
    </div>

    <!-- Terminal image at bottom -->
    <div class="mt-20 relative h-64 rounded-xl overflow-hidden shadow-[0_16px_40px_rgba(26,27,36,0.08)]">
      <img src={terminalImg} alt="Kiosco de autoservicio Ezeat" class="w-full h-full object-cover object-top" loading="lazy" />
      <div class="absolute inset-0 bg-gradient-to-t from-on-background/40 to-transparent flex items-end p-8">
        <p class="text-on-primary font-headline font-bold text-2xl">Tecnología que escala con tu negocio.</p>
      </div>
    </div>

  </div>
</section>

</Layout>

<script>
  // ── Data ────────────────────────────────────────────────────────
  type SolutionKey = 'kioscos' | 'analytics' | 'payments' | 'api';

  const SOLUTIONS: Record<SolutionKey, { icon: string; title: string; desc: string; href: string }> = {
    kioscos: {
      icon: 'point_of_sale',
      title: 'Kioscos de Autoservicio',
      desc: 'Terminales de pedido autónomo que reducen los tiempos de espera hasta un 60% y aumentan el ticket promedio.',
      href: '/services',
    },
    analytics: {
      icon: 'monitoring',
      title: 'Dashboard de Analytics',
      desc: 'Visualiza ventas, inventario y comportamiento de clientes en tiempo real desde un solo panel centralizado.',
      href: '/services',
    },
    payments: {
      icon: 'credit_card',
      title: 'Integración de Pagos',
      desc: 'Procesamiento en menos de 1 segundo con soporte para NFC, QR, tarjetas y wallets digitales.',
      href: '/services',
    },
    api: {
      icon: 'api',
      title: 'API & Integración POS',
      desc: 'Conecta Ezeat con tu stack tecnológico actual sin interrupciones ni migraciones complicadas.',
      href: '/services',
    },
  };

  const WEIGHTS: Record<string, Record<string, Partial<Record<SolutionKey, number>>>> = {
    locations: {
      '1':    { kioscos: 1 },
      '2-5':  { kioscos: 1, analytics: 1 },
      '6-20': { kioscos: 1, analytics: 2, api: 2 },
      '20+':  { kioscos: 1, analytics: 3, api: 3 },
    },
    challenge: {
      wait:   { kioscos: 3 },
      errors: { kioscos: 2, payments: 2 },
      labor:  { kioscos: 3 },
      data:   { analytics: 3 },
    },
    orders: {
      cashier: { kioscos: 2, payments: 1 },
      waiter:  { kioscos: 2 },
      app:     { api: 3 },
      none:    { kioscos: 3, payments: 2 },
    },
    employees: {
      '1-3':  { payments: 1 },
      '4-8':  { kioscos: 2 },
      '9-20': { kioscos: 3, analytics: 1 },
      '20+':  { kioscos: 3, analytics: 2 },
    },
    tracking: {
      yes:     { api: 2 },
      partial: { analytics: 2, api: 1 },
      manual:  { analytics: 3 },
      no:      { analytics: 3, payments: 1 },
    },
  };

  // ── State ────────────────────────────────────────────────────────
  let currentQ = 0;
  const answers: Record<string, string> = {};
  const TOTAL = 5;

  // ── Elements ─────────────────────────────────────────────────────
  const stageHero    = document.getElementById('stage-hero')!;
  const stageStats   = document.getElementById('stage-hero-stats')!;
  const stageQuiz    = document.getElementById('stage-quiz')!;
  const stageResults = document.getElementById('stage-results')!;

  const progressBar  = document.getElementById('progress-bar')!;
  const questionCounter = document.getElementById('question-counter')!;
  const btnStart     = document.getElementById('btn-start')!;
  const btnBack      = document.getElementById('btn-back')!;
  const btnRestart   = document.getElementById('btn-restart')!;
  const btnClose     = document.getElementById('btn-quiz-close')!;
  const resultCards  = document.getElementById('result-cards')!;

  const allQuestions = document.querySelectorAll<HTMLElement>('.quiz-question');

  // ── Helpers ──────────────────────────────────────────────────────
  function showStage(stage: 'hero' | 'quiz' | 'results') {
    stageHero.classList.toggle('hidden', stage !== 'hero');
    stageStats.classList.toggle('hidden', stage !== 'hero');
    stageQuiz.classList.toggle('hidden', stage !== 'quiz');
    stageResults.classList.toggle('hidden', stage !== 'results');
    window.scrollTo({ top: 0, behavior: 'smooth' });
  }

  function updateProgress() {
    const pct = ((currentQ + 1) / TOTAL) * 100;
    progressBar.style.width = `${pct}%`;
    questionCounter.textContent = `Pregunta ${currentQ + 1} de ${TOTAL}`;
    (btnBack as HTMLButtonElement).classList.toggle('hidden', currentQ === 0);
  }

  function showQuestion(index: number) {
    allQuestions.forEach((el, i) => el.classList.toggle('hidden', i !== index));
    updateProgress();
  }

  function computeScores(): Record<SolutionKey, number> {
    const scores: Record<SolutionKey, number> = { kioscos: 0, analytics: 0, payments: 0, api: 0 };
    for (const [qId, val] of Object.entries(answers)) {
      const w = WEIGHTS[qId]?.[val] ?? {};
      for (const [sol, pts] of Object.entries(w)) {
        scores[sol as SolutionKey] += pts as number;
      }
    }
    return scores;
  }

  function renderResults() {
    const scores = computeScores();
    const ranked = (Object.entries(scores) as [SolutionKey, number][])
      .sort(([, a], [, b]) => b - a)
      .slice(0, 3);

    resultCards.innerHTML = ranked.map(([key], i) => {
      const s = SOLUTIONS[key];
      const isTop = i === 0;
      return `
        <div class="flex flex-col rounded-xl p-7 ${isTop
          ? 'bg-primary shadow-[0_20px_48px_rgba(0,44,163,0.2)] md:-translate-y-3 relative'
          : 'bg-surface-container-lowest border border-outline-variant/10 shadow-[0_4px_16px_rgba(26,27,36,0.04)]'}">
          ${isTop ? '<div class="absolute -top-3 left-1/2 -translate-x-1/2 bg-surface-container-lowest text-primary font-bold text-xs px-4 py-1.5 rounded-full shadow-sm uppercase tracking-wider">Recomendado</div>' : ''}
          <div class="w-12 h-12 ${isTop ? 'bg-on-primary/15' : 'bg-primary/8'} rounded-lg flex items-center justify-center ${isTop ? 'text-on-primary' : 'text-primary'} mb-5">
            <span class="material-symbols-outlined text-2xl leading-none">${s.icon}</span>
          </div>
          <h3 class="font-headline font-bold text-xl mb-2 ${isTop ? 'text-on-primary' : 'text-on-background'}">${s.title}</h3>
          <p class="font-body text-sm leading-relaxed ${isTop ? 'text-on-primary/80' : 'text-on-surface-variant'} mb-6 flex-grow">${s.desc}</p>
          <a href="${s.href}" class="inline-flex items-center gap-1.5 font-label font-semibold text-sm ${isTop ? 'text-on-primary' : 'text-primary'} hover:gap-3 transition-all">
            Ver más <span class="material-symbols-outlined text-sm leading-none">arrow_forward</span>
          </a>
        </div>
      `;
    }).join('');
  }

  // ── Event listeners ───────────────────────────────────────────────
  function clearSelections() {
    document.querySelectorAll<HTMLElement>('.quiz-option').forEach(b => {
      b.classList.remove('border-primary', 'bg-primary/5', 'shadow-[0_4px_16px_rgba(0,44,163,0.12)]');
    });
  }

  btnStart.addEventListener('click', () => {
    currentQ = 0;
    clearSelections();
    showStage('quiz');
    showQuestion(0);
  });

  btnClose.addEventListener('click', () => showStage('hero'));

  btnBack.addEventListener('click', () => {
    if (currentQ > 0) {
      currentQ--;
      showQuestion(currentQ);
    }
  });

  btnRestart.addEventListener('click', () => {
    Object.keys(answers).forEach(k => delete answers[k]);
    currentQ = 0;
    clearSelections();
    showStage('hero');
  });

  document.querySelectorAll<HTMLButtonElement>('.quiz-option').forEach(btn => {
    btn.addEventListener('click', () => {
      const q = btn.dataset.q!;
      const v = btn.dataset.v!;
      answers[q] = v;

      // Visual feedback
      const siblings = btn.closest('.grid')?.querySelectorAll('.quiz-option');
      siblings?.forEach(s => s.classList.remove('border-primary', 'bg-primary/5', 'shadow-[0_4px_16px_rgba(0,44,163,0.12)]'));
      btn.classList.add('border-primary', 'bg-primary/5', 'shadow-[0_4px_16px_rgba(0,44,163,0.12)]');

      setTimeout(() => {
        if (currentQ < TOTAL - 1) {
          currentQ++;
          showQuestion(currentQ);
        } else {
          renderResults();
          showStage('results');
        }
      }, 260);
    });
  });
</script>

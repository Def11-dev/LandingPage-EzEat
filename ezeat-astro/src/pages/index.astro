---
import Layout from '../layouts/Layout.astro';

const heroImg    = 'https://lh3.googleusercontent.com/aida-public/AB6AXuCNm5N7HSNrXJnbE9ccYyd3ulRhp5Is_RHDb93gdzCoxb6iufKtz2Z_qI2KTwqfBgmQknWDS5BJ6for7JK-8IDa03PZoJ9NcPVffWB_gMyoBXZD_nRo4yfE0gApP-6fvXCeVmKICpYRRf9VDn2kqfTPvpx9KAECETZUOF5lwench_zCjKXkyZyjST5XfBCnMAWsTF_E35xReyNqTxj1OlCsTawnHL694KHQOz6l4V7V9xg61Xy2ciWCrzpnZE7YyAKXdRe-GTm27vM2';
const terminalImg = 'https://lh3.googleusercontent.com/aida-public/AB6AXuC7kVKpA67m77WIr_OP6QaM9OEuuAgLLF7gCo9P4QY42_Pb-Z6NU82oT-ro-O1X6wTEZr-dWnel0wnrI0oGHDXm08NDTpVAADalzFz--IW6dMDweqJhZznZsYo-avqfhghdOwP79fM9xw_LZr_BbIw0LF9-5-2NOHvYvJygIOoDTcaBQIxt2OwaAuZAvDjnw9cWfAgccA0TrzqokRGPu3EPkDRrcdLHL8N8Rnk0jo_zLWQqpIz9Rp837kO22M1Ym1qnXqNgmiuw1uIA';

const questions = [
  {
    id: 'type',
    step: '01',
    text: '¿Qué tipo de experiencia ofreces?',
    options: [
      { value: 'hotel',     label: 'Hotel',          sub: 'Hospedaje con servicios F&B',    icon: 'hotel' },
      { value: 'restaurant',label: 'Restaurante',    sub: 'Servicio a mesa o casual',        icon: 'restaurant' },
      { value: 'fastfood',  label: 'Fast Food',      sub: 'Autoservicio y orden rápida',     icon: 'storefront' },
      { value: 'cafe',      label: 'Cafetería / Bar',sub: 'Bebidas, snacks y ambiente',      icon: 'local_cafe' },
    ],
  },
  {
    id: 'branches',
    step: '02',
    text: '¿Cuál es el alcance actual de tu marca?',
    options: [
      { value: '1',    label: '1 local',          sub: 'Empezando o consolidando',        icon: 'store' },
      { value: '2-5',  label: '2 a 5 sucursales', sub: 'En expansión regional',           icon: 'storefront' },
      { value: '6-20', label: '6 a 20 sucursales',sub: 'Cadena en crecimiento',           icon: 'location_city' },
      { value: '20+',  label: 'Más de 20',        sub: 'Operación multi-marca o franquicia',icon: 'corporate_fare' },
    ],
  },
  {
    id: 'pain',
    step: '03',
    text: '¿Dónde sientes que se escapa más rentabilidad?',
    options: [
      { value: 'mermas',      label: 'Mermas e inventario',      sub: 'Pérdidas de insumos y stock',      icon: 'inventory_2' },
      { value: 'commissions', label: 'Comisiones de delivery',   sub: 'Rappi, Uber y similares te comen margen', icon: 'local_shipping' },
      { value: 'queues',      label: 'Tiempos de espera',        sub: 'Filas que alejan clientes',          icon: 'hourglass_empty' },
      { value: 'data',        label: 'Falta de datos',           sub: 'Tomas decisiones "a ojo"',          icon: 'bar_chart' },
    ],
  },
  {
    id: 'channel',
    step: '04',
    text: '¿Cuál es el canal de venta preferido de tus clientes?',
    options: [
      { value: 'inperson', label: 'Presencial',         sub: 'La mayoría viene al local',          icon: 'table_restaurant' },
      { value: 'apps',     label: 'Apps de delivery',   sub: 'Rappi, Uber Eats, DiDi Food',       icon: 'delivery_dining' },
      { value: 'web',      label: 'Sitio web propio',   sub: 'Pedidos online directos',            icon: 'language' },
      { value: 'all',      label: 'Todos los canales',  sub: 'Omnicanal o quiero serlo',           icon: 'hub' },
    ],
  },
  {
    id: 'tech',
    step: '05',
    text: '¿Cómo describirías la relación de tu equipo con la tecnología?',
    options: [
      { value: 'digital',  label: 'Muy digital',          sub: 'Adoptamos herramientas sin problema', icon: 'devices' },
      { value: 'basic',    label: 'Básica pero funcional', sub: 'Usamos lo necesario',               icon: 'smartphone' },
      { value: 'low',      label: 'Poca experiencia',      sub: 'Necesitamos algo muy intuitivo',    icon: 'touch_app' },
      { value: 'paper',    label: 'Papel y pluma',         sub: 'Todo es manual por ahora',          icon: 'edit_note' },
    ],
  },
];
---

<Layout
  title="EzEat · El sistema operativo inteligente para HORECAs"
  description="EzEat: el primer sistema operativo inteligente para HORECAs. Diagnóstico gratuito en 60 segundos."
>

<!-- ═══════════════════════════════════════════════
     STAGE 1 · HERO
═══════════════════════════════════════════════ -->
<section id="stage-hero" class="relative min-h-[90vh] flex items-center pt-8 pb-24 overflow-hidden" style="background: linear-gradient(135deg, #0f1729 0%, #141d3d 50%, #1a2450 100%);">
  <!-- Decorative glows -->
  <div class="absolute -top-32 -right-32 w-[600px] h-[600px] rounded-full opacity-20 pointer-events-none" style="background: radial-gradient(circle, #2b49f3 0%, transparent 70%);"></div>
  <div class="absolute -bottom-24 -left-24 w-[400px] h-[400px] rounded-full opacity-10 pointer-events-none" style="background: radial-gradient(circle, #2b49f3 0%, transparent 70%);"></div>

  <div class="max-w-7xl mx-auto px-6 lg:px-8 w-full relative z-10">
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-8 items-center">

      <!-- Text -->
      <div class="lg:col-span-7 space-y-8">
        <!-- Badge chip -->
        <div data-animate="fade-up" class="inline-flex items-center gap-2 bg-white/10 border border-white/20 px-4 py-2 rounded-full">
          <span class="material-symbols-outlined text-[#b0beff] text-base leading-none">bolt</span>
          <span class="text-sm font-label font-medium text-white/90">Diseñado para la nueva generación de fundadores gastronómicos.</span>
        </div>

        <h1 data-animate="fade-up" style="transition-delay:0.1s"
          class="text-5xl md:text-6xl lg:text-[4rem] leading-[1.08] font-headline font-extrabold text-white tracking-tight">
          EzEat: El primer sistema operativo
          <span class="text-[#b0beff]">inteligente</span>
          para HORECAs.
        </h1>

        <p data-animate="fade-up" style="transition-delay:0.2s"
          class="text-xl md:text-2xl text-white/70 font-body max-w-2xl leading-relaxed">
          No todos los negocios crecen igual. Diseñemos la tecnología que el tuyo necesita hoy para escalar mañana.
        </p>

        <div data-animate="fade-up" style="transition-delay:0.3s" class="flex flex-col sm:flex-row gap-4 pt-2">
          <button
            id="btn-start"
            class="bg-primary text-on-primary px-8 py-4 rounded-lg font-label font-semibold text-lg shadow-[0_8px_32px_rgba(43,73,243,0.4)] hover:brightness-110 hover:-translate-y-px transition-all duration-200 flex items-center justify-center gap-2"
          >
            Inicia tu Diagnóstico de Eficiencia
            <span class="material-symbols-outlined text-xl leading-none">arrow_forward</span>
          </button>
          <a href="/services"
            class="border border-white/20 bg-white/10 text-white px-8 py-4 rounded-lg font-label font-medium text-lg hover:bg-white/20 transition-all duration-200 flex items-center justify-center">
            Ver soluciones
          </a>
        </div>
      </div>

      <!-- Mascot image -->
      <div class="lg:col-span-5 relative flex justify-center" data-animate="slide-left" style="transition-delay:0.2s">
        <div class="relative w-72 h-72 lg:w-96 lg:h-96">
          <!-- Glowing circle background -->
          <div class="absolute inset-0 rounded-full opacity-30" style="background: radial-gradient(circle, #2b49f3 0%, transparent 70%);"></div>
          <div class="absolute inset-4 rounded-full bg-white/5 border border-white/10 flex items-center justify-center">
            <img src="/EZ eat (7).png" alt="EzEat mascot" class="w-full h-full object-contain p-6 drop-shadow-2xl" loading="eager" />
          </div>
        </div>

        <!-- Floating stat card -->
        <div class="animate-float absolute -bottom-6 -left-4 lg:-left-10 w-56 p-5 bg-white rounded-xl shadow-[0_16px_40px_rgba(0,0,0,0.3)] hidden lg:block">
          <div class="flex items-center gap-3 mb-2">
            <span class="material-symbols-outlined text-primary text-2xl fill leading-none">speed</span>
            <span class="font-headline font-bold text-on-surface text-lg">40%</span>
          </div>
          <p class="text-xs font-body text-on-surface-variant leading-snug">Reducción promedio en costos laborales con EzEat</p>
        </div>

        <!-- Verified badge -->
        <div class="absolute -top-4 -right-4 px-4 py-2 bg-white rounded-xl shadow-lg hidden lg:flex items-center gap-2">
          <span class="material-symbols-outlined text-primary text-sm leading-none fill">verified</span>
          <span class="text-on-surface text-xs font-label font-semibold">500+ restaurantes</span>
        </div>
      </div>

    </div>
  </div>
</section>

<!-- Stats bar -->
<section id="stage-hero-stats" class="bg-primary py-10">
  <div class="max-w-7xl mx-auto px-6 lg:px-8">
    <div class="grid grid-cols-2 md:grid-cols-4 gap-8 text-center" data-stagger>
      {[
        { value: '500+',  label: 'Restaurantes activos' },
        { value: '<1s',   label: 'Velocidad de transacción' },
        { value: '40%',   label: 'Reducción costos laborales' },
        { value: '24/7',  label: 'Soporte empresarial' },
      ].map(s => (
        <div>
          <div class="text-3xl font-headline font-extrabold text-on-primary">{s.value}</div>
          <div class="text-sm font-body text-on-primary/70 mt-1">{s.label}</div>
        </div>
      ))}
    </div>
  </div>
</section>


<!-- ═══════════════════════════════════════════════
     STAGE 2 · QUIZ
═══════════════════════════════════════════════ -->
<section id="stage-quiz" class="hidden min-h-screen bg-surface py-16">
  <div class="max-w-2xl mx-auto px-6">

    <!-- Progress -->
    <div class="mb-10">
      <div class="flex justify-between items-center mb-3">
        <span class="text-sm font-label font-medium text-on-surface-variant" id="question-counter">Paso 1 de 5</span>
        <button id="btn-quiz-close" class="text-on-surface-variant hover:text-on-surface transition-colors p-1 rounded">
          <span class="material-symbols-outlined text-xl leading-none">close</span>
        </button>
      </div>
      <div class="w-full h-1.5 bg-surface-container-highest rounded-full overflow-hidden">
        <div id="progress-bar" class="h-full bg-primary rounded-full transition-all duration-500 ease-out" style="width:20%"></div>
      </div>
    </div>

    {questions.map((q, qi) => (
      <div data-question={qi} class={qi === 0 ? 'quiz-question' : 'quiz-question hidden'}>
        <div class="inline-flex items-center gap-2 mb-4">
          <span class="text-xs font-label font-bold text-primary bg-primary/8 px-2.5 py-1 rounded-full uppercase tracking-wider">Paso {q.step}</span>
        </div>
        <h2 class="font-headline text-3xl md:text-4xl font-extrabold text-on-background mb-2 leading-tight">
          {q.text}
        </h2>
        <p class="text-on-surface-variant font-body mb-8 text-base">Selecciona la opción que mejor describe tu operación.</p>

        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
          {q.options.map(opt => (
            <button
              data-q={q.id}
              data-v={opt.value}
              class="quiz-option group flex items-start gap-4 p-5 bg-surface-container-lowest rounded-xl border border-outline-variant/15 hover:border-primary/40 hover:bg-surface-container-low hover:shadow-[0_8px_24px_rgba(0,44,163,0.08)] transition-all duration-200 text-left w-full"
            >
              <div class="w-11 h-11 bg-primary/8 rounded-lg flex items-center justify-center text-primary shrink-0 group-hover:bg-primary/15 transition-colors mt-0.5">
                <span class="material-symbols-outlined text-xl leading-none">{opt.icon}</span>
              </div>
              <div>
                <span class="font-body font-semibold text-on-surface text-sm block leading-snug">{opt.label}</span>
                <span class="font-body text-on-surface-variant text-xs mt-0.5 block leading-snug">{opt.sub}</span>
              </div>
            </button>
          ))}
        </div>
      </div>
    ))}

    <!-- Back button -->
    <div class="mt-10 flex items-center gap-4">
      <button id="btn-back" class="hidden flex items-center gap-2 text-on-surface-variant font-label font-medium hover:text-on-surface transition-colors py-2">
        <span class="material-symbols-outlined text-xl leading-none">arrow_back</span>
        Anterior
      </button>
    </div>

  </div>
</section>


<!-- ═══════════════════════════════════════════════
     STAGE 3 · RESULTS
═══════════════════════════════════════════════ -->
<section id="stage-results" class="hidden min-h-screen bg-surface py-20">
  <div class="max-w-4xl mx-auto px-6">

    <!-- Efficiency Score gauge -->
    <div class="text-center mb-12" data-animate="fade-up">
      <div class="inline-flex items-center gap-2 bg-surface-container-highest px-4 py-2 rounded-full mb-8">
        <span class="material-symbols-outlined text-primary text-base leading-none fill">check_circle</span>
        <span class="text-sm font-label font-medium text-on-surface">Diagnóstico completado</span>
      </div>

      <!-- Radial gauge -->
      <div class="flex flex-col items-center mb-6">
        <div class="relative w-48 h-48">
          <svg class="w-full h-full -rotate-90" viewBox="0 0 120 120">
            <circle cx="60" cy="60" r="52" fill="none" stroke="currentColor" stroke-width="8" class="text-surface-container-highest"/>
            <circle
              id="gauge-circle"
              cx="60" cy="60" r="52" fill="none"
              stroke="currentColor" stroke-width="8"
              stroke-linecap="round"
              stroke-dasharray="326.73"
              stroke-dashoffset="326.73"
              class="text-primary transition-all duration-1000 ease-out"
            />
          </svg>
          <div class="absolute inset-0 flex flex-col items-center justify-center">
            <span id="score-display" class="font-headline font-extrabold text-4xl text-on-background">0%</span>
            <span class="text-xs font-label text-on-surface-variant mt-1">eficiencia actual</span>
          </div>
        </div>
      </div>

      <h2 class="font-headline text-3xl md:text-4xl font-extrabold text-on-background mb-3 leading-tight">
        Tu operación está al <span id="score-headline" class="text-primary">—%</span> de su potencial.
      </h2>
      <p id="score-hook" class="text-on-surface-variant font-body text-lg max-w-xl mx-auto mb-2">
        Con EzEat, puedes llegar al <span class="font-bold text-primary">95%</span>.
      </p>
      <p id="pain-text" class="text-on-surface-variant font-body text-base max-w-xl mx-auto"></p>
    </div>

    <!-- Result cards -->
    <div id="result-cards" class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-14"></div>

    <!-- CTAs -->
    <div class="flex flex-col sm:flex-row justify-center gap-4">
      <a href="/contact"
        class="bg-primary text-on-primary px-8 py-4 rounded-lg font-label font-semibold text-base shadow-[0_8px_32px_rgba(0,44,163,0.2)] hover:bg-primary-container hover:-translate-y-px transition-all duration-200 flex items-center justify-center gap-2">
        Agendar demo gratuita
        <span class="material-symbols-outlined text-xl leading-none">calendar_month</span>
      </a>
      <button id="btn-restart"
        class="border border-outline-variant/30 text-on-surface px-8 py-4 rounded-lg font-label font-medium text-base hover:bg-surface-container-low hover:border-primary/30 transition-all duration-200">
        Repetir diagnóstico
      </button>
    </div>

  </div>
</section>


<!-- ═══════════════════════════════════════════════
     TRES PILARES DE VALOR
═══════════════════════════════════════════════ -->
<section class="py-24 bg-surface-container-low">
  <div class="max-w-7xl mx-auto px-6 lg:px-8">
    <div class="text-center max-w-2xl mx-auto mb-16" data-animate="fade-up">
      <span class="text-primary font-label text-sm font-bold uppercase tracking-wider mb-3 block">Por qué somos diferentes</span>
      <h2 class="font-headline text-3xl md:text-4xl font-bold text-on-background">
        Más allá de un POS. Esto es un OS.
      </h2>
    </div>
    <div class="grid md:grid-cols-3 gap-8" data-stagger>
      {[
        {
          icon: 'auto_awesome',
          title: 'Inteligencia de Datos',
          body: 'De datos brutos a Estados Financieros con IA en segundos. Deja de tomar decisiones "a ojo".',
        },
        {
          icon: 'extension',
          title: 'Modularidad Total',
          body: 'Paga solo por lo que usas. Escala funciones conforme abres sucursales. Sin ataduras.',
        },
        {
          icon: 'hub',
          title: 'Omnicanalidad',
          body: 'Tu local, tu web y tus apps de delivery en una sola pantalla. Un cerebro digital, todos tus canales.',
        },
      ].map(p => (
        <div class="bg-surface-container-lowest p-8 rounded-xl group shadow-[0_4px_16px_rgba(26,27,36,0.03)] hover:shadow-[0_12px_32px_rgba(26,27,36,0.07)] transition-all duration-300 hover:-translate-y-1 relative overflow-hidden">
          <div class="absolute top-0 left-0 w-1 h-full bg-primary origin-bottom scale-y-0 group-hover:scale-y-100 transition-transform duration-300 rounded-r"></div>
          <div class="w-14 h-14 bg-primary/8 rounded-xl flex items-center justify-center text-primary mb-6 group-hover:bg-primary/15 transition-colors">
            <span class="material-symbols-outlined text-3xl leading-none">{p.icon}</span>
          </div>
          <h3 class="font-headline text-xl font-bold text-on-background mb-3">{p.title}</h3>
          <p class="font-body text-on-surface-variant leading-relaxed">{p.body}</p>
        </div>
      ))}
    </div>
  </div>
</section>


<!-- ═══════════════════════════════════════════════
     STATS STRIP
═══════════════════════════════════════════════ -->
<section class="py-14 bg-primary">
  <div class="max-w-7xl mx-auto px-6 lg:px-8">
    <div class="grid grid-cols-2 md:grid-cols-4 gap-8 text-center" data-stagger>
      {[
        { value: '+30%',  label: 'Aumento en ticket promedio' },
        { value: '-45%',  label: 'Reducción de mermas' },
        { value: '24/7',  label: 'Soporte humano' },
        { value: '98%',   label: 'Satisfacción de clientes' },
      ].map(s => (
        <div>
          <div class="font-headline font-extrabold text-4xl md:text-5xl text-on-primary mb-1">{s.value}</div>
          <div class="text-sm font-body text-on-primary/70">{s.label}</div>
        </div>
      ))}
    </div>
  </div>
</section>


<!-- ═══════════════════════════════════════════════
     BENEFICIOS
═══════════════════════════════════════════════ -->
<section class="py-24 bg-surface-container-low">
  <div class="max-w-7xl mx-auto px-6 lg:px-8">
    <div class="text-center max-w-2xl mx-auto mb-16" data-animate="fade-up">
      <span class="text-primary font-label text-sm font-bold uppercase tracking-wider mb-3 block">¿Por qué EzEat?</span>
      <h2 class="font-headline text-3xl md:text-4xl font-bold text-on-background">
        Construido para tu realidad operativa
      </h2>
    </div>
    <div class="grid md:grid-cols-3 gap-8" data-stagger>
      {[
        {
          icon: 'bolt',
          title: 'Activa solo lo que necesitas',
          body: 'Empieza con el módulo esencial y agrega funciones conforme tu operación escala. Sin paquetes inflados, sin pagar por lo que no usas.',
        },
        {
          icon: 'shield',
          title: 'Datos seguros y soberanos',
          body: 'Encriptación end-to-end, backups automáticos y cumplimiento de normativas. Tu información nunca sale de tus manos.',
        },
        {
          icon: 'trending_up',
          title: 'Decisiones con IA',
          body: 'Predicciones de demanda, alertas de inventario y reportes financieros automáticos. De datos brutos a insights accionables en segundos.',
        },
      ].map(b => (
        <div class="bg-surface-container-lowest p-8 rounded-xl border border-outline-variant/10 group hover:border-primary/25 hover:shadow-[0_12px_32px_rgba(43,73,243,0.08)] transition-all duration-300 hover:-translate-y-1">
          <div class="w-12 h-12 bg-primary/10 rounded-xl flex items-center justify-center text-primary mb-5 group-hover:bg-primary/20 transition-colors">
            <span class="material-symbols-outlined text-2xl leading-none">{b.icon}</span>
          </div>
          <h3 class="font-headline text-xl font-bold text-on-background mb-3">{b.title}</h3>
          <p class="font-body text-on-surface-variant leading-relaxed text-sm">{b.body}</p>
        </div>
      ))}
    </div>
  </div>
</section>


<!-- ═══════════════════════════════════════════════
     TESTIMONIOS
═══════════════════════════════════════════════ -->
<section class="py-24 bg-surface">
  <div class="max-w-7xl mx-auto px-6 lg:px-8">
    <div class="text-center max-w-2xl mx-auto mb-16" data-animate="fade-up">
      <span class="text-primary font-label text-sm font-bold uppercase tracking-wider mb-3 block">Lo que dicen nuestros clientes</span>
      <h2 class="font-headline text-3xl md:text-4xl font-bold text-on-background">
        Resultados reales, no promesas
      </h2>
    </div>
    <div class="grid md:grid-cols-3 gap-8" data-stagger>
      {[
        {
          name: 'Carlos Mendoza',
          role: 'Dueño',
          business: 'Cadena de Fast Food — CDMX',
          quote: 'Redujimos las mermas en un 38% el primer trimestre. El módulo de inventarios con IA fue un parteaguas para nuestra operación.',
          initial: 'C',
        },
        {
          name: 'Mariana Quintero',
          role: 'Gerente de Operaciones',
          business: 'Restaurante de Autor — Monterrey',
          quote: 'El POS inteligente nos dio visibilidad total del negocio en tiempo real. Ahora tomamos decisiones con datos, no con corazonadas.',
          initial: 'M',
        },
        {
          name: 'Andrés Rivera',
          role: 'Director',
          business: 'Hotel Boutique — Guadalajara',
          quote: 'El Room Service digital cambió la experiencia de nuestros huéspedes. Los pedidos son más rápidos y los errores prácticamente desaparecieron.',
          initial: 'A',
        },
      ].map(t => (
        <div class="bg-surface-container-lowest p-8 rounded-xl border border-outline-variant/10 flex flex-col">
          <span class="material-symbols-outlined text-primary text-3xl leading-none mb-4 fill">format_quote</span>
          <p class="font-body text-on-surface-variant leading-relaxed text-sm flex-grow mb-6">"{t.quote}"</p>
          <div class="flex items-center gap-3 pt-4 border-t border-outline-variant/10">
            <div class="w-10 h-10 rounded-full bg-primary flex items-center justify-center text-on-primary font-headline font-bold text-sm shrink-0">
              {t.initial}
            </div>
            <div>
              <p class="font-headline font-semibold text-on-background text-sm">{t.name}</p>
              <p class="text-xs font-body text-on-surface-variant">{t.role} · {t.business}</p>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>


<!-- ═══════════════════════════════════════════════
     CONFIANZA / AUTORIDAD
═══════════════════════════════════════════════ -->
<section class="py-24 bg-surface">
  <div class="max-w-4xl mx-auto px-6 lg:px-8 text-center" data-animate="scale-in">
    <span class="material-symbols-outlined text-5xl text-primary/80 block mx-auto leading-none mb-8">foundation</span>
    <p class="font-label text-sm font-bold uppercase tracking-wider text-primary mb-4">Infraestructura para escalar</p>
    <blockquote class="font-headline text-3xl md:text-4xl font-bold text-on-background leading-tight mb-6">
      "Construimos EzEat porque la tecnología para restaurantes no debería ser un obstáculo, sino un motor."
    </blockquote>
    <div class="w-16 h-1 bg-primary mx-auto rounded-full mb-8"></div>
    <p class="text-on-surface-variant font-body text-lg max-w-xl mx-auto">
      EzEat no es solo software. Es la infraestructura digital que tus operaciones necesitan para crecer sin límites.
    </p>
    <div class="mt-10">
      <button
        onclick="document.getElementById('btn-start')?.click(); window.scrollTo({top:0,behavior:'smooth'});"
        class="bg-primary text-on-primary px-8 py-4 rounded-lg font-label font-semibold text-lg shadow-[0_8px_32px_rgba(0,44,163,0.25)] hover:bg-primary-container hover:-translate-y-px transition-all duration-200 inline-flex items-center gap-2"
      >
        Inicia tu Diagnóstico de Eficiencia
        <span class="material-symbols-outlined text-xl leading-none">arrow_forward</span>
      </button>
    </div>
  </div>
</section>

</Layout>

<script>
  type SolutionKey = 'kioscos' | 'analytics' | 'roomservice' | 'inventory' | 'delivery' | 'pos';

  const SOLUTIONS: Record<SolutionKey, { icon: string; title: string; desc: string; href: string }> = {
    kioscos: {
      icon: 'point_of_sale',
      title: 'Kioskos de Autoservicio',
      desc: 'Reduce filas hasta un 60% y aumenta el ticket promedio. Tecnología que vende sola.',
      href: '/services',
    },
    analytics: {
      icon: 'monitoring',
      title: 'Analítica Avanzada con IA',
      desc: 'KPIs en tiempo real de todas tus sucursales. De datos brutos a decisiones financieras en segundos.',
      href: '/services',
    },
    roomservice: {
      icon: 'room_service',
      title: 'Room Service Digital',
      desc: 'Pedidos directos a la habitación desde el móvil del huésped. Sin llamadas, sin errores.',
      href: '/services',
    },
    inventory: {
      icon: 'inventory_2',
      title: 'Inventarios con IA',
      desc: 'Elimina mermas y robos hormiga. Alertas automáticas y pronósticos de compra inteligentes.',
      href: '/services',
    },
    delivery: {
      icon: 'delivery_dining',
      title: 'Delivery Integrado',
      desc: 'Un solo tablero para Rappi, Uber Eats y pedidos propios. Reduce comisiones con canal directo.',
      href: '/services',
    },
    pos: {
      icon: 'tablet_android',
      title: 'POS Inteligente',
      desc: 'El corazón digital de tu operación. Rápido, intuitivo y conectado con toda tu infraestructura.',
      href: '/services',
    },
  };

  const PAIN_LABELS: Record<string, string> = {
    mermas: 'mermas e inventario',
    commissions: 'comisiones de delivery',
    queues: 'tiempos de espera y filas',
    data: 'falta de datos para tomar decisiones',
  };

  function calcScore(answers: Record<string, string>): number {
    let score = 95;
    if (answers.tech === 'paper') score -= 25;
    if (answers.pain === 'commissions' || answers.pain === 'mermas') score -= 15;
    const branches = answers.branches;
    if ((branches === '2-5' || branches === '6-20' || branches === '20+') && answers.tech !== 'digital') score -= 10;
    return Math.max(40, Math.min(85, score));
  }

  function getRecommendations(answers: Record<string, string>): SolutionKey[] {
    const scores: Partial<Record<SolutionKey, number>> = {};
    const add = (k: SolutionKey, pts: number) => { scores[k] = (scores[k] ?? 0) + pts; };

    if (answers.type === 'hotel') { add('roomservice', 3); add('kioscos', 1); }
    if (answers.type === 'fastfood') { add('kioscos', 3); add('pos', 1); }
    if (answers.type === 'restaurant') { add('kioscos', 2); add('analytics', 1); }
    if (answers.type === 'cafe') { add('pos', 2); add('analytics', 1); }

    if (answers.pain === 'mermas') { add('inventory', 3); add('analytics', 1); }
    if (answers.pain === 'commissions') { add('delivery', 3); add('kioscos', 1); }
    if (answers.pain === 'queues') { add('kioscos', 3); }
    if (answers.pain === 'data') { add('analytics', 3); }

    if (answers.tech === 'paper') { add('pos', 3); }
    if (answers.tech === 'low') { add('pos', 2); }

    if (answers.channel === 'apps') { add('delivery', 2); }
    if (answers.channel === 'all') { add('delivery', 1); add('analytics', 1); }

    const branches = answers.branches;
    if (branches === '6-20' || branches === '20+') { add('analytics', 2); }

    return (Object.entries(scores) as [SolutionKey, number][])
      .sort(([, a], [, b]) => b - a)
      .slice(0, 3)
      .map(([k]) => k);
  }

  // ── State ─────────────────────────────────────────────────────────
  let currentQ = 0;
  const answers: Record<string, string> = {};
  const TOTAL = 5;

  // ── Elements ──────────────────────────────────────────────────────
  const stageHero    = document.getElementById('stage-hero')!;
  const stageStats   = document.getElementById('stage-hero-stats')!;
  const stageQuiz    = document.getElementById('stage-quiz')!;
  const stageResults = document.getElementById('stage-results')!;
  const progressBar  = document.getElementById('progress-bar')!;
  const questionCounter = document.getElementById('question-counter')!;
  const btnStart     = document.getElementById('btn-start')!;
  const btnBack      = document.getElementById('btn-back')!;
  const btnRestart   = document.getElementById('btn-restart')!;
  const btnClose     = document.getElementById('btn-quiz-close')!;
  const resultCards  = document.getElementById('result-cards')!;
  const allQuestions = document.querySelectorAll<HTMLElement>('.quiz-question');

  function showStage(stage: 'hero' | 'quiz' | 'results') {
    stageHero.classList.toggle('hidden', stage !== 'hero');
    stageStats.classList.toggle('hidden', stage !== 'hero');
    stageQuiz.classList.toggle('hidden', stage !== 'quiz');
    stageResults.classList.toggle('hidden', stage !== 'results');
    window.scrollTo({ top: 0, behavior: 'smooth' });
  }

  function updateProgress() {
    const pct = ((currentQ + 1) / TOTAL) * 100;
    progressBar.style.width = `${pct}%`;
    questionCounter.textContent = `Paso ${currentQ + 1} de ${TOTAL}`;
    (btnBack as HTMLButtonElement).classList.toggle('hidden', currentQ === 0);
  }

  function showQuestion(index: number) {
    allQuestions.forEach((el, i) => el.classList.toggle('hidden', i !== index));
    updateProgress();
  }

  function animateScore(target: number) {
    const circumference = 326.73;
    const circle = document.getElementById('gauge-circle')!;
    const display = document.getElementById('score-display')!;
    const headline = document.getElementById('score-headline')!;

    let current = 0;
    const step = target / 60;
    const interval = setInterval(() => {
      current = Math.min(current + step, target);
      const offset = circumference * (1 - current / 100);
      circle.style.strokeDashoffset = String(offset);
      display.textContent = `${Math.round(current)}%`;
      headline.textContent = `${Math.round(current)}%`;
      if (current >= target) clearInterval(interval);
    }, 16);
  }

  function renderResults() {
    const score = calcScore(answers);
    const recs = getRecommendations(answers);
    const painLabel = PAIN_LABELS[answers.pain] ?? 'operaciones manuales';

    // Update hook text
    const painText = document.getElementById('pain-text')!;
    painText.textContent = `Estás perdiendo margen en ${painLabel}. Con EzEat, puedes llegar al 95%.`;

    // Animate gauge after a short delay
    setTimeout(() => animateScore(score), 300);

    // Save recommendations to localStorage for pricing page pre-selection
    const recMap: Record<SolutionKey, string> = {
      kioscos: 'kioscos', analytics: 'analytics', roomservice: 'roomservice',
      inventory: 'inventory', delivery: 'delivery', pos: 'pos',
    };
    try {
      localStorage.setItem('ezeat_recs', JSON.stringify(recs));
      localStorage.setItem('ezeat_branches', answers.branches ?? '1');
    } catch {}

    resultCards.innerHTML = recs.map((key, i) => {
      const s = SOLUTIONS[key];
      const isTop = i === 0;
      return `
        <div class="flex flex-col rounded-xl p-7 ${isTop
          ? 'bg-primary shadow-[0_20px_48px_rgba(0,44,163,0.2)] md:-translate-y-3 relative'
          : 'bg-surface-container-lowest border border-outline-variant/10 shadow-[0_4px_16px_rgba(26,27,36,0.04)]'}">
          ${isTop ? '<div class="absolute -top-3 left-1/2 -translate-x-1/2 bg-surface-container-lowest text-primary font-bold text-xs px-4 py-1.5 rounded-full shadow-sm uppercase tracking-wider">Recomendado #1</div>' : ''}
          <div class="w-12 h-12 ${isTop ? 'bg-on-primary/15' : 'bg-primary/8'} rounded-lg flex items-center justify-center ${isTop ? 'text-on-primary' : 'text-primary'} mb-5">
            <span class="material-symbols-outlined text-2xl leading-none">${s.icon}</span>
          </div>
          <h3 class="font-headline font-bold text-xl mb-2 ${isTop ? 'text-on-primary' : 'text-on-background'}">${s.title}</h3>
          <p class="font-body text-sm leading-relaxed ${isTop ? 'text-on-primary/80' : 'text-on-surface-variant'} mb-6 flex-grow">${s.desc}</p>
          <a href="${s.href}" class="inline-flex items-center gap-1.5 font-label font-semibold text-sm ${isTop ? 'text-on-primary' : 'text-primary'} hover:gap-3 transition-all">
            Ver más <span class="material-symbols-outlined text-sm leading-none">arrow_forward</span>
          </a>
        </div>
      `;
    }).join('');
  }

  function clearSelections() {
    document.querySelectorAll<HTMLElement>('.quiz-option').forEach(b => {
      b.classList.remove('border-primary', 'bg-primary/5', 'shadow-[0_4px_16px_rgba(0,44,163,0.12)]');
    });
  }

  btnStart.addEventListener('click', () => {
    currentQ = 0;
    clearSelections();
    showStage('quiz');
    showQuestion(0);
  });

  btnClose.addEventListener('click', () => showStage('hero'));

  btnBack.addEventListener('click', () => {
    if (currentQ > 0) { currentQ--; showQuestion(currentQ); }
  });

  btnRestart.addEventListener('click', () => {
    Object.keys(answers).forEach(k => delete answers[k]);
    currentQ = 0;
    clearSelections();
    // Reset gauge
    const circle = document.getElementById('gauge-circle');
    if (circle) (circle as SVGCircleElement).style.strokeDashoffset = '326.73';
    const display = document.getElementById('score-display');
    if (display) display.textContent = '0%';
    showStage('hero');
  });

  document.querySelectorAll<HTMLButtonElement>('.quiz-option').forEach(btn => {
    btn.addEventListener('click', () => {
      const q = btn.dataset.q!;
      const v = btn.dataset.v!;
      answers[q] = v;

      const siblings = btn.closest('.grid')?.querySelectorAll('.quiz-option');
      siblings?.forEach(s => s.classList.remove('border-primary', 'bg-primary/5', 'shadow-[0_4px_16px_rgba(0,44,163,0.12)]'));
      btn.classList.add('border-primary', 'bg-primary/5', 'shadow-[0_4px_16px_rgba(0,44,163,0.12)]');

      setTimeout(() => {
        if (currentQ < TOTAL - 1) {
          currentQ++;
          showQuestion(currentQ);
        } else {
          renderResults();
          showStage('results');
        }
      }, 260);
    });
  });
</script>
